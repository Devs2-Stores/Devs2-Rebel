{% doc %}
  @description Pagination navigation — renders page links with prev/next arrows

  @param paginate - {Object} Pagination object from Liquid

  @example {%- render 'section-pagination', paginate: paginate -%}
{% enddoc %}

{%- if paginate.pages > 1 -%}
  {{ 'section-pagination.css' | asset_url | stylesheet_tag }}
  {%- liquid
    assign t_pagination = 'general.pagination.label' | t
    assign t_prev = 'general.pagination.previous' | t
    assign t_next = 'general.pagination.next' | t
    assign t_page = 'general.pagination.page' | t
  -%}

  <div class="section-pagination">
    <nav aria-label="{{ t_pagination }}" class="section-pagination__nav">
      <ul class="section-pagination__list">
        {%- if paginate.current_page > 1 and paginate.previous -%}
          <li class="section-pagination__item">
            <a
              class="section-pagination__link section-pagination__link--prev"
              href="{{ paginate.previous.url }}"
              title="{{ t_prev }}"
              aria-label="{{ t_prev }}"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
                class="section-pagination__icon"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
              </svg>
            </a>
          </li>
        {%- endif -%}

        {%- for part in paginate.parts -%}
          <li class="section-pagination__item">
            {%- if part.is_link -%}
              <a
                class="section-pagination__link"
                href="{{ part.url }}"
                title="{{ t_page }} {{ part.title }}"
                aria-label="{{ t_page }} {{ part.title }}"
                data-page="{{ part.title }}"
              >
                {{ part.title }}
              </a>
            {%- else -%}
              {%- assign part_title_number = part.title | times: 1 -%}
              {%- if part_title_number == paginate.current_page -%}
                <span class="section-pagination__link section-pagination__link--active" aria-current="page">
                  {{ part.title }}
                </span>
              {%- else -%}
                <span class="section-pagination__link section-pagination__link--ellipsis">
                  {{ part.title }}
                </span>
              {%- endif -%}
            {%- endif -%}
          </li>
        {%- endfor -%}

        {%- if paginate.current_page < paginate.pages -%}
          <li class="section-pagination__item">
            <a
              class="section-pagination__link section-pagination__link--next"
              href="{{ paginate.next.url }}"
              title="{{ t_next }}"
              aria-label="{{ t_next }}"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
                class="section-pagination__icon"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
              </svg>
            </a>
          </li>
        {%- endif -%}
      </ul>
    </nav>
  </div>
{%- endif -%}
