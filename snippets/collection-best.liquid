{% doc %}
  @description Best sellers carousel — reads block settings instead of orphan global settings
  @param {boolean} [enabled=true] - Show/hide best sellers
  @param {string} [title='Best Sellers'] - Section title
  @param {string} [source='current'] - 'current' collection or 'manual'
  @param {object} [manual_collection] - Collection object when source=manual
  @param {number} [limit=10] - Max products to show
  @example {%- render 'collection-best', enabled: block.settings.enabled, title: block.settings.title, source: block.settings.source, manual_collection: block.settings.manual_collection, limit: block.settings.limit -%}
{% enddoc %}

{%- liquid
  if enabled == nil
    assign enabled = true
  endif
  assign limit = limit | default: 10
  assign title = title | default: 'Best Sellers'
  assign source = source | default: 'current'
-%}

{%- if enabled -%}
  {%- liquid
    if source == 'manual' and manual_collection != blank
      assign target_collection = manual_collection
    else
      assign target_collection = collection
    endif
  -%}

  {%- if target_collection and target_collection.products_count > 0 -%}
    <collection-best class="collection-best">
      <div class="collection-best__header">
        <h2 class="collection-best__title">{{ title | escape }}</h2>
      </div>
      <div class="collection-best__content swiper" style="--swiper-cols-mobile: 2; --swiper-cols-tablet: 3; --swiper-cols-laptop: 4; --swiper-cols-desktop: 5; --swiper-gap-mobile: 10px; --swiper-gap-tablet: 15px; --swiper-gap-laptop: 20px; --swiper-gap-desktop: 20px;">
        <div class="swiper-wrapper">
          {%- for product in target_collection.products limit: limit -%}
            <div class="swiper-slide">
              {%- render 'product-card', product: product -%}
            </div>
          {%- endfor -%}
        </div>
        <div class="swiper-pagination"></div>
      </div>
    </collection-best>
  {%- endif -%}
{%- endif -%}