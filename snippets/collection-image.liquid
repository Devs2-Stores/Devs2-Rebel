{%- comment -%}
  Collection image — shows collection banner if image exists.
  Visibility controlled by block.settings.enabled in main-collection section.
{%- endcomment -%}

{%- if collection.image != blank -%}
  {%- assign img_alt = collection.title | escape -%}
  <div class="collection-image">
    {{ collection.image | image_url: width: 2048 | image_tag:
      widths: '480, 600, 1024, 1440, 2048',
      sizes: '100vw',
      alt: img_alt,
      loading: 'eager',
      fetchpriority: 'high',
      class: 'collection-image__img'
    }}
  </div>
{%- endif -%}