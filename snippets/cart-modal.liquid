{{- 'cart-modal.css' | asset_url | stylesheet_tag -}}
<script src="{{ 'cart-modal.js' | asset_url }}" defer="defer"></script>

<cart-modal class="cart-modal-wrapper" role="dialog" aria-modal="true" aria-labelledby="cart-modal-title">
  <button type="button" class="cart-modal-overlay" data-action="close-cart-modal" aria-label="{{ 'accessibility.close' | t }}"></button>
  <div class="cart-modal-panel">
    <div class="cart-modal-header">
      <h2 class="cart-modal-title" id="cart-modal-title">
        {{ 'sections.cart.title' | t }} (<span class="cart-modal-count cart-count">{{ cart.item_count }}</span>)
      </h2>
      <button type="button" class="cart-modal-close" data-action="close-cart-modal" aria-label="{{ 'accessibility.close' | t }}">
        {%- render 'icon', name: 'close' -%}
      </button>
    </div>
    <div class="cart-modal-items">
      <div class="cart-modal-items-loading hidden">
        <div class="cart-modal-items-loading-spinner"></div>
        <p class="cart-modal-items-loading-text">{{ 'accessibility.loading' | t }}</p>
      </div>
      <div class="cart-modal-items-empty hidden">
        {%- render 'icon', name: 'cart' -%}
        <p class="cart-modal-items-empty-text">{{ 'sections.cart.empty' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="cart-modal-items-empty-button">{{ 'general.continue_shopping' | t }}</a>
      </div>
      <div class="cart-modal-items-list"></div>
    </div>
    <div class="cart-modal-footer">
      <div class="cart-modal-summary">
        <div class="cart-modal-summary-row">
          <span class="cart-modal-summary-label">{{ 'sections.cart.estimated_total' | t }}:</span>
          <span class="cart-modal-total cart-price">{%- if cart.total_price == 0 -%}{{ 'products.product.contact' | t }}{%- else -%}{{ cart.total_price | money }}{%- endif -%}</span>
        </div>
        <p class="cart-modal-summary-note">{{ 'sections.cart.taxes_included_shipping_at_checkout_without_policy' | t }}</p>
      </div>
      <div class="cart-modal-actions">
        <a href="{{ routes.cart_url }}" class="cart-modal-action-button cart-modal-action-view">{{ 'general.cart.view_empty_cart' | t }}</a>
        <a href="{{ routes.cart_url }}/checkout" class="cart-modal-action-button cart-modal-action-checkout">
          <span class="cart-modal-action-checkout-inner">
            {%- render 'icon', name: 'cart' -%}
            {{ 'sections.cart.checkout' | t }}
          </span>
        </a>
      </div>
    </div>
  </div>
</cart-modal>