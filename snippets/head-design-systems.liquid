		--bg-body: {{ settings.bg_body | default: '#fff' }};
		--bg-header: {{ settings.bg_header | default: '#fff' }};
		--bg-footer: {{ settings.bg_footer | default: '#1a1a1a' }};
		--bg-card: {{ settings.bg_card | default: '#fff' }};
		--bg-overlay: rgba(0, 0, 0, 0.5);

