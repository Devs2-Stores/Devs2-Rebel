		--font-family-heading: '{{ settings.global_heading_font | split: ':' | first | replace: '+', ' ' }}', sans-serif;
		--font-family-body: '{{ settings.global_body_font | split: ':' | first | replace: '+', ' ' }}', sans-serif;  
		--font-weight-normal: 400;
		--font-weight-medium: 500;
		--font-weight-semibold: 600;
		--font-weight-bold: 700;
