<style>
	:root {
		/* ═══════════ COLORS ═══════════ */
		--color-white: #fff;
		--color-black: #000;
		--color-gray: {{ settings.color_gray | default: '#666' }};
		--color-gray-light: {{ settings.color_gray_light | default: '#f5f5f5' }};
		--color-gray-dark: {{ settings.color_gray_dark | default: '#333' }};
		--color-paragraph: {{ settings.color_paragraph | default: '#000' }};
		--color-primary: {{ settings.color_primary | default: '#F30' }};
		--color-primary-hover: {{ settings.color_primary_hover | default: '#cc2900' }};
		--color-secondary: {{ settings.color_secondary | default: '#E6E1D6' }};
		--color-price: {{ settings.color_price | default: '#F30' }};
		--color-success: {{ settings.color_success | default: '#428445' }};
		--color-error: {{ settings.color_error | default: '#EB001B' }};
		--color-warning: {{ settings.color_warning | default: '#f59e0b' }};
		--color-info: {{ settings.color_info | default: '#3b82f6' }};

