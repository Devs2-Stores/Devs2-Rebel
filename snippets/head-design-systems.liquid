		--space-3xl: 1.75rem;    /* 28px */
		--space-4xl: 2rem;       /* 32px */
		--space-5xl: 2.25rem;    /* 36px */
		--space-6xl: 2.5rem;     /* 40px */

		/* ═══════════ TRANSITIONS ═══════════ */
		--transition-fast: 150ms linear;
		--transition-base: 300ms linear;
		--transition-slow: 500ms linear;

		/* ═══════════ Z-INDEX ═══════════ */
		--z-header: 49;
		--z-dropdown: 100;
		--z-sticky: 200;
		--z-modal: 300;
		--z-overlay: 400;
		--z-toast: 500;

