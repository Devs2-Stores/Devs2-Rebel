{%- doc -%}
  @description Product Card Special — Flash Sale variant with stock bar and discount badge
  @param {object} product - Product object (required)
  @param {number} [sold_count=0] - Number of items sold (simulated via forloop or metafield)
  @param {number} [stock_total=50] - Total stock quantity
  @param {string} [lazyload='lazy'] - Loading strategy: 'lazy' or 'eager'
  @example {%- render 'product-card-special', product: product, sold_count: 42, stock_total: 50 -%}
{%- enddoc -%}
{%- assign price = product.selected_or_first_available_variant.price -%}
{%- assign compare = product.selected_or_first_available_variant.compare_at_price -%}
{%- assign discount = 0 -%}
{%- if compare > price -%}{%- assign discount = compare | minus: price -%}{%- endif -%}
{%- assign discount_percentage = 0 -%}
{%- if discount > 0 -%}{%- assign discount_percentage = discount | times: 100 | divided_by: compare | round -%}{%- endif -%}
{%- assign card_sold = sold_count | default: 0 | plus: 0 -%}
{%- assign card_stock = stock_total | default: 50 | plus: 0 -%}
{%- if card_stock <= 0 -%}{%- assign card_stock = 50 -%}{%- endif -%}
{%- assign card_sold_pct = card_sold | times: 100 | divided_by: card_stock -%}
{%- if card_sold_pct > 100 -%}{%- assign card_sold_pct = 100 -%}{%- endif -%}
{%- assign card_remaining = card_stock | minus: card_sold -%}
{%- if card_remaining < 0 -%}{%- assign card_remaining = 0 -%}{%- endif -%}
{%- if product and product != empty -%}
<product-card class="product-card product-card--special">
  <article class="product-card__wrapper">
    <div class="product-card__media">
      <a class="product-card__media-inner" href="{{ product.url }}" aria-label="{{ 'products.product.view_full_details' | t }}: {{ product.title | escape }}" title="{{ product.title | escape }}">
        {%- if product.featured_image -%}
        <div class="product-card__media-image">
          {%- assign featured_image = product.featured_image.src -%}
          <picture>
            <source media="(max-width: 640px)" srcset="{{ featured_image | image_url: width: 600 }}">
            <source media="(max-width: 1024px)" srcset="{{ featured_image | image_url: width: 1024 }}">
            <img src="{{ featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | default: product.title | escape }}" width="400" height="600" loading="{{ lazyload | default: 'lazy' }}" decoding="async" class="product-card__img-primary">
          </picture>
          {%- if product.images[1] -%}
          {%- assign second_image = product.images[1].src -%}
          <picture>
            <source media="(max-width: 640px)" srcset="{{ second_image | image_url: width: 600 }}">
            <source media="(max-width: 1024px)" srcset="{{ second_image | image_url: width: 1024 }}">
            <img src="{{ second_image | image_url: width: 600 }}" alt="{{ product.images[1].alt | default: product.title | escape }}" width="400" height="600" loading="lazy" decoding="async" class="product-card__img-secondary">
          </picture>
          {%- endif -%}
        </div>
        {%- endif -%}
        {%- unless product.available -%}
        <div class="product-card__badge">{{ settings.product_soldout_text | default: 'products.product.sold_out' | t }}</div>
        {%- endunless -%}
        {%- if discount_percentage > 0 and product.available -%}
        <div class="product-card__badge product-card__badge--discount">-{{ discount_percentage }}%</div>
        {%- endif -%}
      </a>
      <button type="button" class="product-card__quickview" data-action="open-quickview" data-product-handle="{{ product.handle }}" aria-label="{{ 'products.product.quick_view' | t }}: {{ product.title | escape }}" title="{{ 'products.product.quick_view' | t }}">{%- render 'icon', name: 'eye-show' -%}</button>
      <form class="product-card__add-form" action="{{ routes.cart_add_url }}" method="POST">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <button type="submit" class="product-card__add-btn" aria-label="{{ 'products.product.add_to_cart' | t }}: {{ product.title | escape }}" title="{{ 'products.product.add_to_cart' | t }}" {%- unless product.available -%}disabled{%- endunless -%}>{%- render 'icon', name: 'cart' -%}</button>
      </form>
      <button type="button" class="product-card__wishlist" data-action="add-wishlist" data-product-id="{{ product.id }}" data-product-handle="{{ product.handle }}" aria-label="{{ 'general.wishlist.add' | t }}: {{ product.title | escape }}" title="{{ 'general.wishlist.add' | t }}">{%- render 'icon', name: 'heart' -%}</button>
    </div>
    <div class="product-card__content">
      <h3 class="product-card__title"><a href="{{ product.url }}" title="{{ product.title | escape }}">{{ product.title | escape }}</a></h3>
      <div class="product-card__price">
        {%- if price == 0 -%}
        <span class="product-card__price-contact">{{ settings.product_contact_text | default: 'products.product.price.contact' | t }}</span>
        {%- else -%}
        {%- if compare > price -%}<del class="product-card__price-compare">{{ compare | money }}</del>{%- endif -%}
        <span class="product-card__price-sale">{{ price | money }}</span>
        {%- if discount_percentage > 0 -%}
        <span class="product-card__price-discount">-{{ discount_percentage }}%</span>
        {%- endif -%}
        {%- endif -%}
      </div>
      {%- if card_sold > 0 -%}
      <div class="product-card__stock">
        <div class="product-card__stock-bar">
          <div class="product-card__stock-fill {%- if card_sold_pct >= 80 -%} product-card__stock-fill--hot{%- endif -%}" style="width: {{ card_sold_pct }}%;"></div>
        </div>
        <div class="product-card__stock-info">
          {%- if card_sold_pct >= 80 -%}
          <span class="product-card__stock-urgent">
            🔥
            {{ 'products.product.almost_sold_out' | t }}
          </span>
          {%- endif -%}
          <span class="product-card__stock-sold">{{ 'products.product.sold_count' | t: count: card_sold | default: 'Sold' }} {{ card_sold }}</span>
        </div>
      </div>
      {%- endif -%}
    </div>
  </article>
</product-card>
{%- endif -%}
