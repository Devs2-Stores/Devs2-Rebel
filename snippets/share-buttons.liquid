{%- comment -%}
  Share Buttons snippet
  Uses: settings.share_facebook, share_twitter, share_pinterest, share_linkedin, share_email, share_copy
  Accepts: title (string) - label text
{%- endcomment -%}

{%- assign share_url = canonical_url -%}
{%- assign share_url_encoded = share_url | url_encode -%}
{%- assign share_title = page_title | url_encode -%}
{%- assign share_label = title | default: settings.share_label | default: 'Share:' -%}

{{ 'share-buttons.css' | asset_url | stylesheet_tag }}
<script src="{{ 'share-buttons.js' | asset_url }}" defer="defer"></script>
<share-buttons class="share-buttons" data-url="{{ share_url }}" role="group" aria-label="{{ share_label | escape }}">
  <div class="share-buttons__label" id="share-label-{{ section.id | default: 'default' }}">{{ share_label }}</div>
  <div class="share-buttons__items" role="list" aria-labelledby="share-label-{{ section.id | default: 'default' }}">

    {%- if settings.share_facebook -%}
      <div class="share-buttons__item" role="listitem">
        <a href="https://www.facebook.com/sharer/sharer.php?u={{ share_url_encoded }}" target="_blank" rel="noopener noreferrer" title="{{ 'general.social.alt_text.share_on_facebook' | t }}" aria-label="{{ 'general.social.alt_text.share_on_facebook' | t }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
      </div>
    {%- endif -%}

    {%- if settings.share_twitter -%}
      <div class="share-buttons__item" role="listitem">
        <a href="https://twitter.com/intent/tweet?url={{ share_url_encoded }}&text={{ share_title }}" target="_blank" rel="noopener noreferrer" title="{{ 'general.social.alt_text.share_on_twitter' | t }}" aria-label="{{ 'general.social.alt_text.share_on_twitter' | t }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      </div>
    {%- endif -%}

    {%- if settings.share_pinterest -%}
      <div class="share-buttons__item" role="listitem">
        <a href="https://pinterest.com/pin/create/button/?url={{ share_url_encoded }}&description={{ share_title }}" target="_blank" rel="noopener noreferrer" title="{{ 'general.social.alt_text.share_on_pinterest' | t }}" aria-label="{{ 'general.social.alt_text.share_on_pinterest' | t }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0a12 12 0 0 0-4.373 23.178c-.07-.633-.133-1.608.028-2.3.145-.625.938-3.978.938-3.978s-.24-.479-.24-1.187c0-1.113.645-1.943 1.448-1.943.683 0 1.012.512 1.012 1.127 0 .687-.437 1.714-.663 2.668-.189.796.399 1.446 1.184 1.446 1.422 0 2.515-1.5 2.515-3.664 0-1.915-1.377-3.254-3.342-3.254-2.276 0-3.612 1.707-3.612 3.471 0 .688.265 1.425.595 1.826a.24.24 0 0 1 .056.23c-.061.252-.196.796-.222.907-.035.146-.116.177-.268.107-1-.465-1.624-1.926-1.624-3.1 0-2.523 1.835-4.84 5.286-4.84 2.775 0 4.932 1.977 4.932 4.62 0 2.757-1.739 4.976-4.151 4.976-.811 0-1.573-.421-1.834-.919l-.498 1.902c-.181.695-.669 1.566-.995 2.097A12 12 0 1 0 12 0z"/></svg>
        </a>
      </div>
    {%- endif -%}

    {%- if settings.share_linkedin -%}
      <div class="share-buttons__item" role="listitem">
        <a href="https://www.linkedin.com/shareArticle?mini=true&url={{ share_url_encoded }}&title={{ share_title }}" target="_blank" rel="noopener noreferrer" title="Share on LinkedIn" aria-label="Share on LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>
    {%- endif -%}

    {%- if settings.share_email -%}
      <div class="share-buttons__item" role="listitem">
        <a href="mailto:?subject={{ share_title }}&body={{ share_url_encoded }}" title="{{ 'general.share.copy_to_clipboard' | t }}" aria-label="Share via Email">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </a>
      </div>
    {%- endif -%}

    {%- if settings.share_copy -%}
      <div class="share-buttons__item" role="listitem">
        <button type="button" class="share-buttons__copy" data-url="{{ share_url }}" title="{{ 'general.share.copy_to_clipboard' | t }}" aria-label="{{ 'general.share.copy_to_clipboard' | t }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        </button>
      </div>
    {%- endif -%}

  </div>
</share-buttons>