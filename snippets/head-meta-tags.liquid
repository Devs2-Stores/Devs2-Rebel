<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="view-transition" content="same-origin">
<meta name="revisit-after" content="1 day">
<meta name="HandheldFriendly" content="true">
<meta name="theme-color" content="#ffffff">
<link rel="shortcut icon" href="{{ 'favicon.png' | asset_url }}" type="image/png">
<link rel="expect" href="#MainContent" id="view-transition-render-blocker">
<link rel="canonical" href="{{ canonical_url | replace: 'http://', 'https://' }}">
<link rel="alternate" href="{{ canonical_url | replace: 'http://', 'https://' }}" hreflang="vi-VN">
{%- if paginate -%}
{%- if paginate.previous -%}
<link rel="prev" href="{{ paginate.previous.url }}">{%- endif -%}
{%- if paginate.next -%}
<link rel="next" href="{{ paginate.next.url }}">{%- endif -%}
{%- endif -%}
<title>
  {{ page_title }}
  {%- if current_tags %} - {{ current_tags | join: ', ' }}{% endif -%}
  {%- if current_page != 1 %} - Page {{ current_page }}{% endif -%}
  {%- unless page_title contains shop.name %} - {{ shop.name }}{% endunless %}
</title>
{%- if page_description != blank -%}
<meta name="description" content="{{ page_description | escape }}">
{%- else -%}
<meta name="description" content="{{ shop.description | default: shop.name | escape }}">
{%- endif -%}

{%- if template contains 'search' -%}
<meta name="robots" content="noindex, nofollow">
{%- elsif current_page > 1 -%}
<meta name="robots" content="noindex, follow">
{%- elsif template contains 'customers' -%}
<meta name="robots" content="noindex, nofollow">
{%- else -%}
<meta name="robots" content="index, follow">
{%- endif -%}

{%- if template contains 'product' -%}
<meta property="og:type" content="product">
<meta property="og:title" content="{{ product.title | strip_html | strip_newlines | escape }}">
<meta property="og:image" content="https:{{ product.featured_image.src | img_url: 'grande'  | remove: 'http:'}}">
<meta property="og:image:secure_url" content="https:{{ product.featured_image.src | img_url: 'grande'  | remove: 'http:'}}">
<meta property="og:image:width" content="{{ product.featured_image.width }}">
<meta property="og:image:height" content="{{ product.featured_image.height }}">
<meta property="og:price:amount" content="{{ product.price | money_without_currency | remove: ',' | remove: '₫'}}">
<meta property="og:price:currency" content="{{ shop.currency }}">
{%- elsif template contains 'collection' %}
<meta property="og:type" content="website">
<meta property="og:title" content="{{ collection.title | strip_html | strip_newlines | escape }}">
{%- assign img_tag = '&lt;' | append: 'img' -%}
{%- if collection.image -%}
{%- assign src = collection.image.src | remove: 'https:' | remove: 'http:' -%}
{%- else -%}
{%- if collection.description contains img_tag -%}
{%- assign src = collection.description | split: 'src="' -%}
{%- assign src = src[1] | split: '"' | first | remove: 'https:' | remove: 'http:' -%}
{%- else -%}
{%- assign src = 'share_fb_home.png' | asset_url | remove: 'https:' | remove: 'http:'-%}
{%- endif -%}
{%- endif -%}
<meta property="og:image" content="https:{{ src }}">
<meta property="og:image:secure_url" content="https:{{ src }}">
{%- elsif template contains 'article' %}
<meta property="og:type" content="article">
<meta property="og:title" content="{{ article.title | strip_html | strip_newlines | escape }}">
{%- assign img_art = '&lt;' | append: 'img' -%}
{%- if article.image -%}
{%- assign src_art = article.image.src | remove: 'https:' | remove: 'http:' -%}
{%- else -%}
{%- if article.content contains img_art -%}
{%- assign src_art = article.content | split: 'src="' -%}
{%- assign src_art = src_art[1] | split: '"' | first | remove: 'https:' | remove: 'http:' -%}
{%- endif -%}
{%- endif -%}
{%- if src_art  -%}
<meta property="og:image" content="https:{{ src_art }}">
<meta property="og:image:secure_url" content="https:{{ src_art }}">
{%- else -%}
<meta property="og:image" content="https:{{ 'share_fb_home.png' | asset_url | remove: 'https:' | remove: 'http:' }}">
<meta property="og:image:secure_url" content="https:{{ 'share_fb_home.png' | asset_url | remove: 'https:' | remove: 'http:' }}">
{%- endif -%}
{%- else -%}
<meta property="og:type" content="website">
<meta property="og:title" content="{{ page_title | strip_html | strip_newlines | escape }}">
<meta property="og:image" content="https:{{ 'share_fb_home.png' | asset_url | remove: 'https:' | remove: 'http:' }}">
<meta property="og:image:secure_url" content="https:{{ 'share_fb_home.png' | asset_url | remove: 'https:' | remove: 'http:' }}">
{%- endif -%}
{%- if page_description -%}
<meta property="og:description" content="{{ page_description | strip_html | strip_newlines | escape }}">
{%- else -%}
<meta property="og:description" content="{{ shop.description | default: shop.name | strip_html | strip_newlines | escape }}">
{%- endif -%}
<meta property="og:url" content="{{ canonical_url | replace: 'http://', 'https://' }}">
<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:locale" content="vi_VN">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ page_title | strip_html | strip_newlines | escape }}">
{%- if page_description -%}
<meta name="twitter:description" content="{{ page_description | strip_html | strip_newlines | escape }}">
{%- else -%}
<meta name="twitter:description" content="{{ shop.description | default: shop.name | strip_html | strip_newlines | escape }}">
{%- endif -%}
{%- if template contains 'product' -%}
<meta name="twitter:image" content="https:{{ product.featured_image.src | img_url: 'grande' | remove: 'http:' }}">
{%- elsif template contains 'collection' and src -%}
<meta name="twitter:image" content="https:{{ src }}">
{%- elsif template contains 'article' and src_art -%}
<meta name="twitter:image" content="https:{{ src_art }}">
{%- else -%}
<meta name="twitter:image" content="https:{{ 'share_fb_home.png' | asset_url }}">
{%- endif -%}

{%- if template == 'index' -%}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": {{ shop.name | json }},
    "url": "{{ shop.url | replace: 'http://', 'https://' }}",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "{{ shop.url | replace: 'http://', 'https://' }}/search?type=product&q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
</script>
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "url": "{{ shop.url | replace: 'http://', 'https://' }}",
    {%- if settings.header_logo != blank -%} "logo": "https:{{ 'header_logo.png' | asset_url | remove: 'http:' | remove: 'https:' }}",
    {%- endif -%} "sameAs": [
      {%- assign social_links = '' -%}
      {%- if settings.footer_social_facebook != blank -%}{%- assign social_links = social_links | append: '"' | append: settings.footer_social_facebook | append: '",' -%}{%- endif -%}
      {%- if settings.footer_social_instagram != blank -%}{%- assign social_links = social_links | append: '"' | append: settings.footer_social_instagram | append: '",' -%}{%- endif -%}
      {%- if settings.footer_social_youtube != blank -%}{%- assign social_links = social_links | append: '"' | append: settings.footer_social_youtube | append: '",' -%}{%- endif -%}
      {%- if settings.footer_social_tiktok != blank -%}{%- assign social_links = social_links | append: '"' | append: settings.footer_social_tiktok | append: '",' -%}{%- endif -%}
      {{ social_links | remove_last: ',' }}
    ]
    {%- if settings.footer_phone != blank -%}
    ,"contactPoint": {
      "@type": "ContactPoint",
      "telephone": {{ settings.footer_phone | json }},
      "contactType": "customer service",
      "availableLanguage": "Vietnamese"
    }
    {%- endif -%}
    {%- if settings.footer_address != blank -%}
    ,"address": {
      "@type": "PostalAddress",
      "streetAddress": {{ settings.footer_address | json }},
      "addressCountry": "VN"
    }
    {%- endif -%}
  }
</script>
{%- endif -%}
{%- if template contains 'product' -%}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Trang chủ", "item": "{{ shop.url | replace: 'http://', 'https://' }}" }
      {%- if product.collections.size > 0 -%}
      ,{ "@type": "ListItem", "position": 2, "name": {{ product.collections.first.title | json }}, "item": "{{ shop.url | replace: 'http://', 'https://' }}{{ product.collections.first.url }}" }
      ,{ "@type": "ListItem", "position": 3, "name": {{ product.title | json }} }
      {%- else -%}
      ,{ "@type": "ListItem", "position": 2, "name": {{ product.title | json }} }
      {%- endif -%}
    ]
  }
</script>
{%- endif -%}
{%- if template contains 'collection' -%}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Trang chủ", "item": "{{ shop.url | replace: 'http://', 'https://' }}" },
      { "@type": "ListItem", "position": 2, "name": {{ collection.title | json }} }
    ]
  }
</script>
{%- endif -%}
{%- if template contains 'article' -%}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": {{ article.title | json }},
    "url": "{{ shop.url | replace: 'http://', 'https://' }}{{ article.url }}",
    {%- if article.image -%}
    "image": "https:{{ article.image.src | remove: 'http:' | remove: 'https:' }}",
    {%- endif -%}
    "datePublished": "{{ article.created_at | date: '%Y-%m-%dT%H:%M:%S' }}",
    {%- if article.updated_at -%}
    "dateModified": "{{ article.updated_at | date: '%Y-%m-%dT%H:%M:%S' }}",
    {%- endif -%}
    "author": {
      "@type": "Person",
      "name": {{ article.author | json }}
    },
    "publisher": {
      "@type": "Organization",
      "name": {{ shop.name | json }}
      {%- if settings.header_logo != blank -%}
      ,"logo": {
        "@type": "ImageObject",
        "url": "https:{{ 'header_logo.png' | asset_url | remove: 'http:' | remove: 'https:' }}"
      }
      {%- endif -%}
    },
    "description": {{ article.excerpt | default: article.content | strip_html | truncatewords: 50 | json }}
  }
</script>
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Trang chủ", "item": "{{ shop.url | replace: 'http://', 'https://' }}" },
      { "@type": "ListItem", "position": 2, "name": {{ blog.title | json }}, "item": "{{ shop.url | replace: 'http://', 'https://' }}{{ blog.url }}" },
      { "@type": "ListItem", "position": 3, "name": {{ article.title | json }} }
    ]
  }
</script>
{%- endif -%}