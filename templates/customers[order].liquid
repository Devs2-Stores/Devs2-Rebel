<div class="order-template">
  {%- include 'section-breadcrumb' -%}
  <div class="page-width">
    <h1 class="order-template__title">Chi tiết đơn hàng {{ order.name }}</h1>
    <div class="account-template__grid">
      <div class="order-template__sidebar">
        {%- include 'customer-sidebar' -%}
      </div>
      <div class="order-template__wrapper">
        <div class="order-template__content">
          <div class="order-template__header">
            <div class="order-template__header-row">
              <div class="order-template__header-item">
                <p class="order-template__label">Ngày tạo:</p>
                <p class="order-template__value">{{ order.created_at | date: '%d/%m/%Y' }}</p>
              </div>
              <div class="order-template__header-item">
                <p class="order-template__label">Mã đơn hàng:</p>
                <p class="order-template__value">{{ order.name }}</p>
              </div>
            </div>
            <div class="order-template__header-row">
              <div class="order-template__header-item">
                <p class="order-template__label">Trạng thái thanh toán:</p>
                <p class="order-template__value">
                  {%- if order.cancelled -%}
                  <span class="status-cancelled">Đơn hàng đã hủy</span>
                  {%- else -%}
                  {%- case order.financial_status -%}
                  {%- when 'paid' -%}<span class="status-paid">Đã thanh toán</span>
                  {%- when 'authorized' -%}<span class="status-refunded">Chờ xác nhận</span>
                  {%- when 'pending' -%}<span class="status-pending">Chưa thanh toán</span>
                  {%- when 'partially_paid' -%}<span class="status-pending">Thanh toán một phần</span>
                  {%- when 'partially_refunded' -%}<span class="status-pending">Hoàn trả một phần</span>
                  {%- when 'refunded' -%}<span class="status-refunded">Hoàn trả toàn bộ</span>
                  {%- when 'voided' -%}<span class="status-default">Vô hiệu</span>
                  {%- else -%}<span class="status-default">{{ order.financial_status }}</span>
                  {%- endcase -%}
                  {%- endif -%}
                </p>
              </div>
              <div class="order-template__header-item">
                <p class="order-template__label">Trạng thái vận chuyển:</p>
                <p class="order-template__value">
                  {%- if order.cancelled -%}
                  <span class="status-cancelled">Đã hủy</span>
                  {%- else -%}
                  {%- if order.shipping_status != null and order.shipping_status != "" -%}
                  {%- case order.shipping_status -%}
                  {%- when 'delivered' -%}<span class="status-paid">Đã giao hàng</span>
                  {%- when 'delivering' -%}<span class="status-pending">Đang giao hàng</span>
                  {%- when 'returning' -%}<span class="status-refunded">Chờ chuyển hoàn</span>
                  {%- when 'returned' -%}<span class="status-pending">Đã chuyển hoàn</span>
                  {%- when 'cancelled' -%}<span class="status-cancelled">Hủy giao hàng</span>
                  {%- else -%}<span class="status-refunded">Chờ lấy hàng</span>
                  {%- endcase -%}
                  {%- else -%}
                  <span class="status-default">Chưa chuyển</span>
                  {%- endif -%}
                  {%- endif -%}
                </p>
              </div>
            </div>
            {%- if order.fulfillments.last.tracking_number != null and order.fulfillments.last.tracking_number != "" -%}
            <div class="order-template__tracking">
              <p class="order-template__label">Mã vận đơn:</p>
              <a href="{{ order.fulfillments.last.tracking_url }}" class="order-template__tracking-link" title="Tracking Number" target="_blank" rel="noopener noreferrer">
                {{ order.fulfillments.last.tracking_number }}
                {%- include 'icon' with name: 'arrow', size: '14' -%}
              </a>
            </div>
            {%- endif -%}
          </div>
          <div class="order-template__details">
            {%- if order.shipping_address -%}
            <div class="order-template__detail-item">
              <h4 class="order-template__detail-title">
                <i class="icon">{%- include 'icon' with name: 'location' -%}</i>
                Địa chỉ giao hàng
              </h4>
              <div class="order-template__detail-content">
                <p class="order-template__detail-name">{{ order.customer.name }}</p>
                <p class="order-template__detail-text">
                  {%- capture shipping_address_parts -%}
                  {%- if order.shipping_address.address1 != blank -%}{{ order.shipping_address.address1 }}|{%- endif -%}
                  {%- if order.shipping_address.address2 != blank -%}{{ order.shipping_address.address2 }}|{%- endif -%}
                  {%- if order.shipping_address.ward != blank -%}{{ order.shipping_address.ward }}|{%- endif -%}
                  {%- if order.shipping_address.district != blank -%}{{ order.shipping_address.district }}|{%- endif -%}
                  {%- if order.shipping_address.city != blank -%}{{ order.shipping_address.city }}|{%- endif -%}
                  {%- if order.shipping_address.province != blank -%}{{ order.shipping_address.province }}|{%- endif -%}
                  {%- if order.shipping_address.country != blank -%}{{ order.shipping_address.country }}|{%- endif -%}
                  {%- endcapture -%}
                  {%- assign shipping_parts_array = shipping_address_parts | split: '|' -%}
                  {{ shipping_parts_array | join: ', ' }}
                </p>
                {%- if order.shipping_address.phone != null and order.shipping_address.phone != "" -%}
                <p class="order-template__detail-text">Điện thoại: {{ order.shipping_address.phone }}</p>
                {%- endif -%}
              </div>
            </div>
            {%- endif -%}
            <div class="order-template__detail-item">
              <h4 class="order-template__detail-title">
                <i class="icon">{%- include 'icon' with name: 'tag' -%}</i>
                Thanh toán
              </h4>
              <div class="order-template__detail-content">
                <p class="order-template__detail-text">
                  {%- if order.gateway == "manual" -%}Thủ công{%- else -%}{{ order.gateway }}{%- endif -%}
                </p>
              </div>
            </div>
            <div class="order-template__detail-item">
              <h4 class="order-template__detail-title">
                <i class="icon">{%- include 'icon' with name: 'clipboard' -%}</i>
                Ghi chú
              </h4>
              <div class="order-template__detail-content">
                <p class="order-template__detail-text">
                  {%- if order.note != null and order.note != "" -%}{{ order.note }}{%- else -%}Không có ghi chú{%- endif -%}
                </p>
              </div>
            </div>
          </div>
          <div class="order-template__items">
            <h4 class="order-template__items-title">
              <i class="icon">{%- include 'icon' with name: 'order' -%}</i>
              Sản phẩm đã đặt
            </h4>
            <div class="order-template__table-wrapper">
              <table class="order-template__table">
                <thead>
                  <tr>
                    <th class="text-left">Sản phẩm</th>
                    <th class="text-right">Đơn giá</th>
                    <th class="text-center">Số lượng</th>
                    <th class="text-right">Tổng</th>
                  </tr>
                </thead>
                <tbody>
                  {%- for line_item in order.line_items -%}
                  <tr>
                    <td>
                      <div class="order-template__product-cell">
                        {%- if line_item.image -%}
                        <a href="{{ line_item.product.url }}" title="{{ line_item.title | escape }}" class="order-template__product-image">
                          <img src="{{ line_item.image | img_url: 'compact' }}" alt="{{ line_item.title | escape }}" width="80" height="80" loading="lazy" decoding="async">
                        </a>
                        {%- endif -%}
                        <div class="order-template__product-info">
                          <a href="{{ line_item.product.url }}" class="order-template__product-title" title="{{ line_item.title | escape }}">{{ line_item.title }}</a>
                          {%- if line_item.variant.title != null and line_item.variant.title != "" and line_item.variant.title != 'Default Title' -%}
                          <p class="order-template__product-variant">{{ line_item.variant.title }}</p>
                          {%- endif -%}
                          {%- if line_item.sku != null and line_item.sku != "" -%}
                          <p class="order-template__product-sku">Mã SP: {{ line_item.sku }}</p>
                          {%- endif -%}
                        </div>
                      </div>
                    </td>
                    <td class="text-right">{{ line_item.price | money }}</td>
                    <td class="text-center">{{ line_item.quantity }}</td>
                    <td class="text-right order-template__product-total">{{ line_item.quantity | times: line_item.price | money }}</td>
                  </tr>
                  {%- endfor -%}
                </tbody>
              </table>
            </div>
          </div>
          <div class="order-template__summary">
            <div class="order-template__summary-content">
              {%- if order.discount.code != null and order.discount.code != "" -%}
              <div class="order-template__summary-row">
                <span class="order-template__label">Khuyến mãi {{ order.discount.code }}:</span>
                <span class="order-template__discount">-{{ order.total_discounts | money }}</span>
              </div>
              {%- endif -%}
              <div class="order-template__summary-row">
                <span class="order-template__label">Phí vận chuyển:</span>
                <span class="order-template__value">
                  {%- if order.shipping_price != null and order.shipping_price != "" -%}{{ order.shipping_price | money }}{%- else -%}{{ order.shipping_methods[0].price | default: 0 | money }}{%- endif -%}
                  {%- if order.shipping_methods[0].title != null and order.shipping_methods[0].title != "" -%}
                  <span class="order-template__shipping-method">({{ order.shipping_methods[0].title }})</span>
                  {%- endif -%}
                </span>
              </div>
              <div class="order-template__summary-row order-template__summary-row--total">
                <span>Tổng tiền:</span>
                <span>{{ order.total_price | money }}</span>
              </div>
            </div>
          </div>
          <div class="order-template__actions">
            <a href="/account?view=orders" class="button-primary active" title="Quay lại danh sách đơn hàng">
              {%- include 'icon' with name: 'chevron-left', size: '16' -%}
              Quay lại danh sách đơn hàng
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>