{%- if cart.item_count > 0 -%}
{%- assign cart_data_attr = '' -%}
{%- assign cart_empty_attr = 'style="display: none;"' -%}
{%- else -%}
{%- assign cart_data_attr = 'style="display: none;"' -%}
{%- assign cart_empty_attr = '' -%}
{%- endif -%}
<cart-template>
  {%- include 'section-breadcrumb' -%}
  <div class="page-width">
    <h1 class="cart-template__title">
      {{ settings.cart_template_title | default: 'Giỏ hàng của bạn' }}
      <span class="cart-template__count">({{ cart.item_count }} sản phẩm)</span>
    </h1>
    {%- if settings.cart_template_content != blank -%}
    <p class="cart-template__content">{{ settings.cart_template_content }}</p>
    {%- endif -%}
    <div class="cart-template__wrapper">
      <div class="cart-template__data" {{ cart_data_attr }}>
        {%- include 'cart-items' -%}
        <div class="cart-template__footer">
          <div class="cart-template__note">
            <h4>Ghi chú đơn hàng</h4>
            <label for="cart-template__note-input" class="sr-only">Ghi chú</label>
            <textarea name="note" id="cart-template__note-input" placeholder="Nhập ghi chú cho đơn hàng nếu có...">{{ cart.note }}</textarea>
            <h4 class="invoice-title">Thông tin xuất hóa đơn (tuỳ chọn)</h4>
            <label for="invoice-name" class="sr-only">Tên công ty</label>
            <input type="text" name="invoice[name]" id="invoice-name" value="{{ cart.attributes.invoice_name }}" class="invoice-input" placeholder="Tên công ty">
            <label for="invoice-taxcode" class="sr-only">Mã số thuế</label>
            <input type="text" name="invoice[taxcode]" id="invoice-taxcode" value="{{ cart.attributes.invoice_taxcode }}" class="invoice-input" placeholder="Mã số thuế">
            <label for="invoice-address" class="sr-only">Địa chỉ xuất hóa đơn</label>
            <input type="text" name="invoice[address]" id="invoice-address" value="{{ cart.attributes.invoice_address }}" class="invoice-input" placeholder="Địa chỉ xuất hóa đơn">
          </div>
          <div class="cart-template__summary">{%- include 'cart-total' -%}</div>
        </div>
      </div>
      <div class="cart-template__empty" {{ cart_empty_attr }}>
        <span class="empty-icon">{%- include 'icon' with name: 'sad' -%}</span>
        <p class="empty-text">{{ settings.cart_template_empty_text | default: 'Giỏ hàng của bạn hiện đang trống.' }}</p>
        <a href="{{ settings.cart_template_empty_button_link | default: '/collections/all' }}" class="button-primary">
          {{- settings.cart_template_empty_button | default: 'Tiếp tục mua sắm' -}}
        </a>
      </div>
      <div class="cart-template__upsale">
        {%- if settings.cart_template_upsale_products_check -%}
        {%- assign upsale_collection = collections[settings.cart_template_upsale_products_collection] -%}
        {%- assign upsale_limit = settings.cart_template_upsale_products_limit | default: 3 | plus: 0 -%}
        {%- if upsale_collection != blank -%}
        <section class="cart-template__upsale-products">
          <h4>{{ settings.cart_template_upsale_products_title | default: 'Sản phẩm bạn có thể thích' }}</h4>
          <ul class="upsale-list" role="list">
            {%- for product in upsale_collection.products limit: upsale_limit -%}
            <li class="upsale-item" role="listitem">
              <a href="{{ product.url }}" class="upsale-item__image">
                <img src="{{ product.featured_image | img_url: 'large' }}" alt="{{ product.title | escape }}" loading="lazy" decoding="async" width="120" height="120">
              </a>
              <div class="upsale-item__info">
                <a href="{{ product.url }}" class="upsale-item__title">{{ product.title }}</a>
                <p class="upsale-item__vendor">{{ product.vendor }}</p>
                <p class="upsale-item__price">{{ product.price | money }}</p>
              </div>
            </li>
            {%- endfor -%}
          </ul>
        </section>
        {%- endif -%}
        {%- endif -%}
        {%- if settings.cart_template_promotions_check -%}
        <section class="cart-template__upsale-promotions">
          <h4>{{ settings.cart_template_promotions_title | default: 'Ưu đãi hôm nay' }}</h4>
          <ul class="promotions-list">
            {%- if settings.cart_template_promotions_item_check_1 and settings.cart_template_promotions_item_text_1 != blank -%}
            <li>{{ settings.cart_template_promotions_item_text_1 }}</li>
            {%- endif -%}
            {%- if settings.cart_template_promotions_item_check_2 and settings.cart_template_promotions_item_text_2 != blank -%}
            <li>{{ settings.cart_template_promotions_item_text_2 }}</li>
            {%- endif -%}
            {%- if settings.cart_template_promotions_item_check_3 and settings.cart_template_promotions_item_text_3 != blank -%}
            <li>{{ settings.cart_template_promotions_item_text_3 }}</li>
            {%- endif -%}
          </ul>
        </section>
        {%- endif -%}
        {%- if settings.cart_template_promotion_banner_check -%}
        <section class="cart-template__promotion-banner">
          <a href="{{ settings.cart_promotion_banner_link }}"><img src="{{ 'cart_promotion_banner_image.png' | img_url: 'grande' | asset_url }}" alt="{{ settings.cart_promotion_banner_title | escape }}" width="800" height="200" loading="lazy" decoding="async"></a>
        </section>
        {%- endif -%}
      </div>
    </div>
  </div>
</cart-template>
