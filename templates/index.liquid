<section class="section-countdown-banner section-padding scroll-fade-up">
  <div class="section-countdown-banner-container">
    <div class="section-countdown-banner-background">
      {%- capture image_desktop -%}section_countdown_banner_bg_d.jpg{%- endcapture -%}
      {%- capture image_mobile -%}section_countdown_banner_bg_m.jpg{%- endcapture -%}
      <picture>
        <source width="1920" height="640" media="(min-width: 768px)" srcset="{{ image_desktop | asset_url }}">
        <source width="800" height="800" media="(min-width: 0)" srcset="{{ image_mobile | asset_url }}">
        <img width="1920" height="640" loading="lazy" decoding="async" src="{{ image_desktop | asset_url }}" alt="{{ settings.section_countdown_banner_heading | escape }}">
      </picture>
    </div>
    <div class="section-countdown-banner-content">
      <div class="page-width">
        <div class="section-countdown-banner-content-inner">
          {%- if settings.section_countdown_banner_heading != blank -%}
          <h2 class="section-countdown-banner-content-heading section-heading">
            {{ settings.section_countdown_banner_heading }}
          </h2>
          {%- endif -%}
          {%- if settings.section_countdown_banner_description != blank -%}
          <div class="section-countdown-banner-content-description section-content">
            {{ settings.section_countdown_banner_description }}
          </div>
          {%- endif -%}
          {%- if settings.section_countdown_banner_time != blank -%}
          <div class="section-countdown-banner-content-countdown">
            {%- assign countdown_color = settings.section_countdown_banner_countdown_color | default: '#F30' -%}
            {%- assign countdown_text_color = settings.section_countdown_banner_countdown_text_color | default: '#F9F9F9' -%}
            <div data-time="{{ settings.section_countdown_banner_time }}" class="countdownLoop-vi" style="--countdown-color: {{ countdown_color }}; --countdown-text-color: {{ countdown_text_color }};"></div>
          </div>
          {%- endif -%}
          {%- if settings.section_countdown_banner_button != blank and settings.section_countdown_banner_button_link != blank -%}
          <div class="section-countdown-banner-content-button">
            <a href="{{ settings.section_countdown_banner_button_link }}" class="button button-primary big white" title="{{ settings.section_countdown_banner_button | escape }}">
              {{ settings.section_countdown_banner_button }}
            </a>
          </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>
