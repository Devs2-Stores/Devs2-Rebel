          <a class="section-group-banners-item-link" href="{{ settings[link] }}" title="{{ settings[button] | escape }}">
            <img width="600" height="600" loading="lazy" decoding="async" src="{{ image | asset_url }}" alt="{{ settings[button] | escape }}" title="{{ settings[button] | escape }}">
            <span class="section-group-banners-item-button button-primary white">{{ settings[button] }}</span>
          </a>
        </div>
        {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
