{%- if settings.section_blog_check -%}
{%- assign blog_handle = settings.section_blog_handle | default: 'all' -%}
{%- assign blog_source = blogs[blog_handle] -%}
{%- assign blog_limit = settings.section_blog_limit | default: 8 | plus: 0 -%}
<section class="section-home-blog section-padding scroll-fade-up">
  <div class="page-width">
    <div class="section-home-blog__head">
      <div class="section-home-blog__head-left">
        {%- if settings.section_blog_subtitle != blank -%}
        <span class="section-home-blog__subtitle section-sub-heading">{{ settings.section_blog_subtitle }}</span>
        {%- endif -%}
        {%- if settings.section_blog_title != blank -%}
        <h2 class="section-home-blog__title section-heading">
          {%- if settings.section_blog_link != blank -%}
          <a href="{{ settings.section_blog_link }}" class="section-heading-link" title="{{ settings.section_blog_title | escape }}">
            {{- settings.section_blog_title -}}
          </a>
          {%- else -%}
          {{ settings.section_blog_title }}
          {%- endif -%}
        </h2>
        {%- endif -%}
      </div>
      {%- if settings.section_blog_view_all != blank and settings.section_blog_link != blank -%}
      <a href="{{ settings.section_blog_link }}" class="section-home-blog__view-all" title="{{ settings.section_blog_view_all | escape }}">
        {{- settings.section_blog_view_all -}}
        {%- include 'icon' with name: 'arrow' -%}
      </a>
      {%- endif -%}
    </div>
    <div class="section-home-blog__carousel">
      {%- if blog_source != null and blog_source.articles_count > 0 -%}
      <div class="swiper section-home-blog__swiper">
        <div class="swiper-wrapper">
          {%- for article in blog_source.articles limit: blog_limit -%}
          {%- assign lazyload = 'lazy' -%}
          {%- if forloop.index <= 4 -%}{%- assign lazyload = 'eager' -%}{%- endif -%}
          <div class="swiper-slide">
            {%- include 'article-card' with article, lazyload: lazyload -%}
          </div>
          {%- endfor -%}
        </div>
      </div>
      <div class="swiper-button-prev section-home-blog__nav-prev"></div>
      <div class="swiper-button-next section-home-blog__nav-next"></div>
      {%- else -%}
      <p class="empty-message">Chưa có bài viết nào.</p>
      {%- endif -%}
    </div>
  </div>
</section>
{%- endif -%} 
{%- if settings.section_trending_check -%}
<section class="section-trending section-padding scroll-fade-up">
  <div class="page-width">
    <div class="section-trending__head">
      <h2 class="section-trending__title section-heading">
        {%- if settings.section_trending_link != blank -%}
        <a href="{{ settings.section_trending_link }}" class="section-heading-link" title="{{ settings.section_trending_title | escape }}">
          {{- settings.section_trending_title -}}
        </a>
        {%- else -%}
        {{ settings.section_trending_title }}
        {%- endif -%}
      </h2>
      {%- if settings.section_trending_view_all != blank and settings.section_trending_link != blank -%}
      <a href="{{ settings.section_trending_link }}" class="section-trending__view-all" title="{{ settings.section_trending_view_all | escape }}">
        {{- settings.section_trending_view_all -}}
      </a>
      {%- endif -%}
    </div>
    <div class="section-trending__items">
      {%- assign trending_collection = collections[settings.section_trending_collection] -%}
      {%- if trending_collection != null and trending_collection.products_count > 0 -%}
      {%- for product in trending_collection.products limit: 10 -%}
      {%- assign price = product.variants[0].price -%}
      {%- assign compare = product.variants[0].compare_at_price -%}
      <a href="{{ product.url }}" class="section-trending__item" title="{{ product.title | escape }}">
        <span class="section-trending__rank">
          {%- if forloop.index < 10 -%}0{%- endif -%}{{ forloop.index -}}
        </span>
        <div class="section-trending__image">
          {%- if product.featured_image -%}
          <img width="64" height="64" loading="lazy" decoding="async" src="{{ product.featured_image.src | img_url: 'small' }}" alt="{{ product.featured_image.alt | default: product.title | escape }}">
          {%- endif -%}
        </div>
        <div class="section-trending__content">
          <p class="section-trending__name">{{ product.title }}</p>
          <p class="section-trending__meta">
            {%- if price == 0 -%}
            {{ settings.product_contact_text | default: 'Liên hệ' }}
            {%- else -%}
            {%- if compare > price -%}
            <del class="section-trending__price-compare">{{ compare | money }}</del>
            {%- endif -%}
            <span class="section-trending__price-sale">{{ price | money }}</span>
            {%- endif -%}
            {%- unless product.available -%}
            &bull; {{ settings.product_soldout_text | default: 'Hết hàng' }}
            {%- endunless -%}
          </p>
        </div>
        <span class="section-trending__arrow">
          {%- include 'icon' with name: 'arrow' -%}
        </span>
      </a>
      {%- endfor -%}
      {%- else -%}
      <p class="empty-message">Không có sản phẩm trong bộ sưu tập này.</p>
      {%- endif -%}
    </div>
  </div>
</section>
{%- endif -%}
