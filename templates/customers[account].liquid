<div class="account-template">
  {%- include 'section-breadcrumb' -%}
  <div class="page-width">
    <h1 class="account-template__title">Tài khoản của bạn</h1>
    <div class="account-template__grid">
      <div class="account-template__sidebar">
        {%- include 'customer-sidebar' -%}
      </div>
      <div class="account-template__wrapper">

        <!-- THÔNG TIN TÀI KHOẢN -->
        <div class="account-template__info">
          <div class="account-template__info-header">
            <h4 class="account-template__info-title">
              <i class="icon">{%- include 'icon' with name: 'info' -%}</i>
              Thông tin tài khoản
            </h4>
          </div>
          <ul class="account-template__info-list">
            <li><strong>Họ tên:</strong> <span>{{ customer.last_name }} {{ customer.first_name }}</span></li>
            <li><strong>Email:</strong> <span>{{ customer.email }}</span></li>
            {%- unless customer.default_address.phone == blank -%}
            <li><strong>Số điện thoại:</strong> <span>{{ customer.default_address.phone }}</span></li>
            {%- endunless -%}
            {%- unless customer.default_address.company == blank -%}
            <li><strong>Công ty:</strong> <span>{{ customer.default_address.company }}</span></li>
            {%- endunless -%}
            {%- if customer.default_address -%}
            <li>
              <strong>Địa chỉ:</strong>
              <span>
                {%- capture addr -%}
                {%- if customer.default_address.address1 != blank -%}{{ customer.default_address.address1 }}|{%- endif -%}
                {%- if customer.default_address.province != blank -%}{{ customer.default_address.province }}|{%- endif -%}
                {%- if customer.default_address.country != blank -%}{{ customer.default_address.country }}|{%- endif -%}
                {%- endcapture -%}
                {{ addr | split: '|' | join: ', ' }}
              </span>
            </li>
            {%- endif -%}
          </ul>
        </div>

        <!-- ĐƠN HÀNG GẦN ĐÂY -->
        <div class="account-template__order">
          <h4 class="account-template__section-title">
            <i>{%- include 'icon' with name: 'order' -%}</i>
            Đơn hàng gần đây
          </h4>
          <div class="account-template__order-items">
            {%- if customer.orders.size > 0 -%}
            <div class="account-template__order-table">
              {%- for order in customer.orders limit: 5 -%}
              {%- assign order_url = order.customer_url | default: order.url -%}
              {%- if order_url == blank -%}{%- assign order_url = '/account/orders/' | append: order.id -%}{%- endif -%}
              <div class="account-template__order-row">
                <div class="account-template__order-row-main">
                  <a href="{{ order_url }}" class="account-template__order-name" title="Xem chi tiết {{ order.name }}">{{ order.name }}</a>
                  <span class="account-template__order-meta">{{ order.created_at | date: '%d/%m/%Y' }} &middot; {{ order.line_items.size }} sản phẩm</span>
                </div>
                <div class="account-template__order-row-statuses">
                  <span class="account-template__status-group">
                    <span class="account-template__label">Thanh toán:</span>
                    {%- if order.cancelled -%}
                    <span class="status-cancelled">Đã hủy</span>
                    {%- else -%}
                    {%- case order.financial_status -%}
                    {%- when 'paid' -%}<span class="status-paid">Đã thanh toán</span>
                    {%- when 'authorized' -%}<span class="status-pending">Chờ xác nhận</span>
                    {%- when 'pending' -%}<span class="status-pending">Chưa thanh toán</span>
                    {%- when 'partially_paid' -%}<span class="status-pending">Thanh toán một phần</span>
                    {%- when 'refunded' -%}<span class="status-refunded">Hoàn trả</span>
                    {%- else -%}<span class="status-default">{{ order.financial_status }}</span>
                    {%- endcase -%}
                    {%- endif -%}
                  </span>
                  <span class="account-template__status-group">
                    <span class="account-template__label">Vận chuyển:</span>
                    {%- case order.shipping_status -%}
                    {%- when 'delivered' -%}<span class="status-paid">Đã giao hàng</span>
                    {%- when 'delivering' -%}<span class="status-pending">Đang giao hàng</span>
                    {%- when 'returning' -%}<span class="status-pending">Chờ chuyển hoàn</span>
                    {%- when 'returned' -%}<span class="status-pending">Đã chuyển hoàn</span>
                    {%- when 'cancelled' -%}<span class="status-cancelled">Hủy giao hàng</span>
                    {%- else -%}<span class="status-pending">Chờ lấy hàng</span>
                    {%- endcase -%}
                  </span>
                </div>
                <div class="account-template__order-row-right">
                  <strong class="account-template__order-total">{{ order.total_price | money }}</strong>
                  <a href="{{ order_url }}" class="account-template__order-link">Xem chi tiết →</a>
                </div>
              </div>
              {%- endfor -%}
            </div>
            {%- else -%}
            <div class="account-template__order-empty">
              <i>{%- include 'icon' with name: 'sad' -%}</i>
              <p>Bạn chưa từng đặt đơn hàng nào trước đây.</p>
              <a href="/collections/all" class="button-primary active">Mua sắm ngay</a>
            </div>
            {%- endif -%}
          </div>
        </div>

        <!-- DANH SÁCH ĐỊA CHỈ -->
        <div class="account-template__address">
          <h4 class="account-template__section-title">
            <i>{%- include 'icon' with name: 'location' -%}</i>
            Danh sách địa chỉ
          </h4>
          <div class="account-template__address-items">
            {%- if customer.addresses.size > 0 -%}
            <div class="account-template__address-list">
              {%- for address in customer.addresses limit: 3 -%}
              <div class="account-template__address-card">
                {%- if address.id == customer.default_address.id -%}
                <span class="account-template__address-badge">Mặc định</span>
                {%- endif -%}
                <p class="account-template__address-name"><strong>{{ address.last_name }} {{ address.first_name }}</strong></p>
                {%- unless address.company == blank -%}
                <p class="account-template__address-row"><span class="account-template__label">Công ty:</span> {{ address.company }}</p>
                {%- endunless -%}
                {%- unless address.address1 == blank -%}
                <p class="account-template__address-row"><span class="account-template__label">Địa chỉ:</span> {{ address.address1 }}</p>
                {%- endunless -%}
                {%- unless address.province == blank -%}
                <p class="account-template__address-row"><span class="account-template__label">Tỉnh/TP:</span> {{ address.province }}{%- unless address.country == blank -%}, {{ address.country }}{%- endunless -%}</p>
                {%- endunless -%}
                {%- unless address.phone == blank -%}
                <p class="account-template__address-row"><span class="account-template__label">SĐT:</span> {{ address.phone }}</p>
                {%- endunless -%}
              </div>
              {%- endfor -%}
            </div>
            <div class="account-template__address-add">
              <a href="/account/addresses" class="button-primary active" title="Quản lý địa chỉ">Quản lý địa chỉ</a>
            </div>
            {%- else -%}
            <div class="account-template__address-empty">
              <i>{%- include 'icon' with name: 'sad' -%}</i>
              <p>Bạn chưa có địa chỉ nào.</p>
              <a href="/account/addresses" class="button-primary active">Thêm địa chỉ mới</a>
            </div>
            {%- endif -%}
          </div>
        </div>

      </div>
    </div>
  </div>
</div>