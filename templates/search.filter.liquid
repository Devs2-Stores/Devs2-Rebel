{%- layout none -%}
{%- paginate search.results by settings.collection_template_products_per_page -%}
{%- if search.results.size == 0 -%}
<div class="collection-template__no-products">
	<p>Không tìm thấy sản phẩm phù hợp</p>
</div>
{%- else -%}
<ul class="product-cards collection-template__products">
	{%- for product in search.results -%}
	{%- assign lazyload = "lazy" -%}
	{%- assign fetchpriority = "auto" -%}
	{%- if forloop.index <= 3 -%}
		{%- assign lazyload = "eager" -%}
	{%- endif -%}
	{%- if forloop.first -%}
		{%- assign fetchpriority = "high" -%}
	{%- endif -%}
	<li class="product-cards__item">
		{%- include 'product-card' with product, lazyload: lazyload, fetchpriority: fetchpriority, show_vendor: true -%}
	</li>
	{%- endfor -%}
</ul>
{%- endif -%}
{%- if paginate.pages > 1 -%}
<div class="collection-template__pagination">
	{%- include 'section-pagination' -%}
</div>
{%- endif -%}
{%- endpaginate -%}