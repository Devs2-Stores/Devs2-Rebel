<div class="change-password-template">
  {%- include 'section-breadcrumb' -%}
  <div class="page-width">
    <h1 class="change-password-template__title">Phục hồi mật khẩu</h1>
    <div class="account-template__grid">
      <div class="change-password-template__sidebar">
        {%- include 'customer-sidebar' -%}
      </div>
      <div class="change-password-template__wrapper">
        <div class="change-password-template__form">
          {%- form 'reset_customer_password' -%}
          {%- if form.errors -%}
          <div class="form-error" role="alert">{{ form.errors | default_errors }}</div>
          {%- endif -%}
          {%- if form.posted_successfully or form.posted_successfully == 'true' -%}
          <div class="form-success">
            <p class="form-success__text">Phục hồi mật khẩu thành công!</p>
          </div>
          {%- else -%}
          <div class="form-info">
            <p>Để đảm bảo tính bảo mật, bạn vui lòng đặt lại mật khẩu với ít nhất 8 ký tự.</p>
          </div>
          {%- endif -%}
          <change-password-form class="form form-change-password">

            <toggle-password class="form-group">
              <label for="new-password" class="label-password">
                <span class="required">Mật khẩu mới</span>
                <div class="form-group-input">
                  {%- include 'icon' with name: 'password' -%}
                  <input type="password" id="new-password" class="form-control" name="customer[password]" required minlength="8" placeholder="Nhập mật khẩu mới (ít nhất 8 ký tự)">
                  {%- include 'icon' with name: 'eye-show', class: 'icon-eye-show right' -%}
                  {%- include 'icon' with name: 'eye-hide', class: 'icon-eye-hide right', style: 'display:none;' -%}
                </div>
              </label>
            </toggle-password>
            <toggle-password class="form-group">
              <label for="confirm-password" class="label-password">
                <span class="required">Xác nhận lại mật khẩu</span>
                <div class="form-group-input">
                  {%- include 'icon' with name: 'password' -%}
                  <input type="password" id="confirm-password" class="form-control" name="customer[password_confirmation]" required minlength="8" placeholder="Nhập lại mật khẩu mới">
                  {%- include 'icon' with name: 'eye-show', class: 'icon-eye-show right' -%}
                  {%- include 'icon' with name: 'eye-hide', class: 'icon-eye-hide right', style: 'display:none;' -%}
                </div>
              </label>
            </toggle-password>
            <div class="form-group">
              <button type="submit" class="button-primary active form-submit" title="Xác nhận">Xác nhận</button>
            </div>
            <div class="form-group form-group--text-center">
              <a class="link" href="/account" title="Quay lại tài khoản">Quay lại tài khoản</a>
            </div>
          </change-password-form>
          {%- endform -%}
        </div>
      </div>
    </div>
  </div>
</div>