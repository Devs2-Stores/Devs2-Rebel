{%- include 'section-breadcrumb' -%}
<contact-page class="page-contact">
  <section class="contact-hero">
    <div class="page-width">
      <div class="contact-hero__wrap">
        <h1 class="contact-hero__title">{{ settings.page_contact_title | default: 'Liên hệ với chúng tôi' }}</h1>
        {%- if settings.page_contact_description != blank -%}
        <p class="contact-hero__description">{{ settings.page_contact_description }}</p>
        {%- endif -%}
      </div>
    </div>
  </section>

  <section class="contact-main section-padding">
    <div class="page-width">
      <div class="contact-main__wrap">
        <div class="contact-main__info">
          <h2 class="contact-main__info-title">Thông tin liên hệ</h2>

          {%- if settings.page_contact_address != blank -%}
          <div class="contact-main__info-item">
            <div class="contact-main__info-item-icon">
              {%- include 'icon' with name: 'location' -%}
            </div>
            <div class="contact-main__info-item-content">
              <h3 class="contact-main__info-item-title">Địa chỉ</h3>
              <p class="contact-main__info-item-text">{{ settings.page_contact_address }}</p>
            </div>
          </div>
          {%- endif -%}

          {%- if settings.page_contact_phone != blank -%}
          <div class="contact-main__info-item">
            <div class="contact-main__info-item-icon">
              {%- include 'icon' with name: 'phone' -%}
            </div>
            <div class="contact-main__info-item-content">
              <h3 class="contact-main__info-item-title">Điện thoại</h3>
              <a href="tel:{{ settings.page_contact_phone | replace: ' ', '' }}" class="contact-main__info-item-text" title="Gọi {{ settings.page_contact_phone }}">{{ settings.page_contact_phone }}</a>
            </div>
          </div>
          {%- endif -%}

          {%- if settings.page_contact_email != blank -%}
          <div class="contact-main__info-item">
            <div class="contact-main__info-item-icon">
              {%- include 'icon' with name: 'email' -%}
            </div>
            <div class="contact-main__info-item-content">
              <h3 class="contact-main__info-item-title">Email</h3>
              <a href="mailto:{{ settings.page_contact_email }}" class="contact-main__info-item-text" title="Email {{ settings.page_contact_email }}">{{ settings.page_contact_email }}</a>
            </div>
          </div>
          {%- endif -%}

          {%- if settings.page_contact_hours != blank -%}
          <div class="contact-main__info-item">
            <div class="contact-main__info-item-icon">
              {%- include 'icon' with name: 'calendar' -%}
            </div>
            <div class="contact-main__info-item-content">
              <h3 class="contact-main__info-item-title">Giờ làm việc</h3>
              <p class="contact-main__info-item-text">{{ settings.page_contact_hours }}</p>
            </div>
          </div>
          {%- endif -%}

          {%- if settings.page_contact_show_social -%}
          <div class="contact-main__info-social">
            <h3 class="contact-main__info-social-title">Theo dõi chúng tôi</h3>
            {%- include 'shop-social' -%}
          </div>
          {%- endif -%}
        </div>

        <div class="contact-main__form">
          <h2 class="contact-main__form-title">Gửi tin nhắn</h2>
          {% form 'contact' %}
          {%- if form.posted_successfully? -%}
          <div class="contact-form__success" role="alert">
            <div class="contact-form__success-icon">
              {%- include 'icon' with name: 'check-circle' -%}
            </div>
            <p class="contact-form__success-text">Cảm ơn bạn đã liên hệ! Chúng tôi sẽ phản hồi sớm nhất có thể.</p>
          </div>
          {%- endif -%}

          {%- if form.errors -%}
          <div class="contact-form__error" role="alert">
            <div class="contact-form__error-icon">
              {%- include 'icon' with name: 'alert-circle' -%}
            </div>
            <p class="contact-form__error-text">Vui lòng kiểm tra lại thông tin và thử lại.</p>
          </div>
          {%- endif -%}

          <div class="form-group">
            <label for="contact-name">
              <span class="required">Họ và tên</span>
              <input type="text" id="contact-name" name="contact[name]" class="form-control" placeholder="Nhập họ và tên của bạn" required aria-required="true" value="{%- if form.name -%}{{ form.name }}{%- endif -%}">
            </label>
            {%- if form.errors contains 'name' -%}
            <span class="form-error-message">{{ form.errors.translated_fields['name'] }} {{ form.errors.messages['name'] }}</span>
            {%- endif -%}
          </div>

          <div class="form-group">
            <label for="contact-email">
              <span class="required">Email</span>
              <input type="email" id="contact-email" name="contact[email]" class="form-control" placeholder="email@example.com" required aria-required="true" value="{%- if form.email -%}{{ form.email }}{%- endif -%}">
            </label>
            {%- if form.errors contains 'email' -%}
            <span class="form-error-message">{{ form.errors.translated_fields['email'] }} {{ form.errors.messages['email'] }}</span>
            {%- endif -%}
          </div>

          <div class="form-group">
            <label for="contact-phone">
              <span>Số điện thoại</span>
              <input type="tel" id="contact-phone" name="contact[phone]" class="form-control" placeholder="0123 456 789" value="{%- if form.phone -%}{{ form.phone }}{%- endif -%}">
            </label>
          </div>

          <div class="form-group">
            <label for="contact-message">
              <span class="required">Nội dung</span>
              <textarea id="contact-message" name="contact[body]" class="form-control" rows="6" placeholder="Nhập nội dung tin nhắn của bạn..." required aria-required="true">{%- if form.body -%}{{ form.body }}{%- endif -%}</textarea>
            </label>
            {%- if form.errors contains 'body' -%}
            <span class="form-error-message">{{ form.errors.translated_fields['body'] }} {{ form.errors.messages['body'] }}</span>
            {%- endif -%}
          </div>

          <div class="form-group">
            <button type="submit" class="contact-form__submit button-primary" aria-label="Gửi tin nhắn">
              <span class="contact-form__submit-text">Gửi tin nhắn</span>
              {%- include 'icon' with name: 'send' -%}
            </button>
          </div>
          {%- endform -%}
        </div>
      </div>
    </div>
  </section>

  {%- if settings.page_contact_show_map and settings.page_contact_map_embed != blank -%}
  <section class="contact-map">
    <div class="contact-map__wrap">
      <div class="contact-map__embed">
        {{ settings.page_contact_map_embed }}
      </div>
    </div>
  </section>
  {%- endif -%}

  {%- if page.content != blank -%}
  <section class="contact-content section-padding">
    <div class="page-width">
      <div class="contact-content__wrap">
        {{ page.content }}
      </div>
    </div>
  </section>
  {%- endif -%}
</contact-page>