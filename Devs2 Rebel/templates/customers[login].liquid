<div class="login-template">
  {%- include 'section-breadcrumb' -%}
  <div class="page-width">
    <h1 class="login-template__title">Đăng nhập</h1>
    <div class="login-template__wrapper">
      <auth-form class="login-template__form login-layout">
        <div class="form form-login" id="form-login">
          {%- form 'customer_login' -%}
          <div class="form-error">
            {%- for error in form.errors -%}{{ form.errors.messages[error] }}<br />{%- endfor -%}
          </div>
          <div class="form-group">
            <label for="login-email">
              <span class="required">Email</span>
              <div class="form-group-input">
                {%- include 'icon' with name: 'email' -%}
                <input type="email" id="login-email" class="form-control" name="customer[email]" required placeholder="Nhập địa chỉ email của bạn">
              </div>
            </label>
          </div>
          <toggle-password class="form-group">
            <label for="login-password" class="label-password">
              <span class="required">Mật khẩu</span>
              <a href="#recover" data-layout="recover-layout" class="auth-layout-trigger" title="Quên mật khẩu">Quên mật khẩu?</a>
              <div class="form-group-input">
                {%- include 'icon' with name: 'password' -%}
                <input type="password" id="login-password" class="form-control" name="customer[password]" required placeholder="Nhập mật khẩu của bạn">
                {%- include 'icon' with name: 'eye-show', class: 'icon-eye-show right' -%}
                {%- include 'icon' with name: 'eye-hide', class: 'icon-eye-hide right', style: 'display:none;' -%}
              </div>
            </label>
          </toggle-password>
          <div class="form-group">
            <button type="submit" class="button-primary active form-submit" title="Đăng nhập">ĐĂNG NHẬP</button>
          </div>
          <div class="form-group form-group--text-center">
            <span class="form-text">Bạn chưa có tài khoản? </span><a class="link" href="/account/register" title="Tạo tài khoản">Tạo tài khoản</a>
          </div>
          {%- endform -%}
        </div>
        <div class="form form-recover" id="form-recover">
          {%- form 'recover_customer_password' -%}
          {%- if form.errors -%}
          <div class="form-error" role="alert">{{ form.errors | default_errors }}</div>
          {%- endif -%}
          <div class="form-group">
            <label for="recover-email">
              <span class="required">Email</span>
              <div class="form-group-input">
                {%- include 'icon' with name: 'email' -%}
                <input type="email" id="recover-email" class="form-control" name="email" required placeholder="Nhập địa chỉ email của bạn">
              </div>
            </label>
          </div>
          <div class="form-group">
            <button type="submit" class="button-primary active form-submit" title="Gửi">Gửi</button>
          </div>
          <div class="form-group form-group--text-center">
            <span class="form-text">Bạn đã có tài khoản? </span><a class="link auth-layout-trigger" href="#login" data-layout="login-layout" title="Đăng nhập">Đăng nhập</a>
          </div>
          {%- endform -%}
        </div>
      </auth-form>
      <div class="login-template__content">
        <div class="login-template__quote-icon">{%- include 'icon' with name: 'quote-open' -%}</div>
        <div class="login-template__quote-text">
          <p>Giỏ hàng đang chờ bạn! Đăng nhập để xem lịch sử đơn hàng, lưu sản phẩm yêu thích và tận hưởng trải nghiệm mua sắm thuận tiện hơn.</p>
        </div>
        <div class="login-template__quote-icon login-template__quote-icon--right">{%- include 'icon' with name: 'quote-close' -%}</div>
      </div>
    </div>
  </div>
</div>
