            </div>
          </label>
        </div>
        <div class="form-group">
          <label for="new_company">
            <span>Công ty</span>
            <div class="form-group-input">
              {%- include 'icon' with name: 'store' -%}
              <input type="text" name="address[company]" id="new_company" placeholder="Nhập tên công ty (nếu có)" value="{{ form.company }}" class="form-control">
            </div>
          </label>
        </div>
        <div class="form-group">
          <label for="new_address1">
            <span class="required">Địa chỉ</span>
            <div class="form-group-input">
              {%- include 'icon' with name: 'location' -%}
              <input type="text" name="address[address1]" id="new_address1" placeholder="Nhập số nhà, tên đường" value="{{ form.address1 }}" class="form-control">
            </div>
          </label>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="new_country">
              <span class="required">Quốc gia</span>
