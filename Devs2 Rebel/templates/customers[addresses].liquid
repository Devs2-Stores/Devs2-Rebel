                  <option value="" disabled selected>Chọn quốc gia</option>
                  {{ country_option_tags }}
                </select>
              </div>
            </label>
          </div>
          <div class="form-group not-vn">
            <label for="new_province">
              <span>Tỉnh thành</span>
              <div class="form-group-input">
                {%- include 'icon' with name: 'location' -%}
                <select name="address[province]" id="new_province" class="form-control add" data-address-type="province" data-address-zone="new">
                  <option value="" disabled selected>Chọn tỉnh thành</option>
                </select>
              </div>
            </label>
          </div>
        </div>

        <div class="form-group">
          <label for="new_zip">
            <span>Mã Zip</span>
            <div class="form-group-input">
              {%- include 'icon' with name: 'location' -%}
              <input type="text" name="address[zip]" id="new_zip" placeholder="Nhập mã zip (nếu có)" value="{{ form.zip }}" class="form-control">
            </div>
          </label>
        </div>
        <div class="form-group">
          <label class="form-checkbox">
            <input type="checkbox" name="address[default]" id="new_is_default" value="true">
            <span>Đặt là địa chỉ mặc định?</span>
          </label>
        </div>
      </div>
    </div>
    <div class="address-modal-footer">
      <button type="button" class="button-primary" data-action="close-address-modal">Hủy</button>
      <button type="submit" title="Thêm địa chỉ" class="button-primary active">Thêm địa chỉ</button>
    </div>
    {%- endform -%}
  </div>
</address-modal>