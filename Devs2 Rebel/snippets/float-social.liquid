{%- if settings.float_social_enable -%}
<float-social class="float-social" data-position="{{ settings.float_social_position | default: 'right' }}">
  <button type="button" class="float-social__toggle" aria-label="Liên hệ" aria-expanded="false">
    <span class="float-social__toggle-icon">
      <svg class="icon" width="24" height="24"><use href="#icon-comments" /></svg>
    </span>
    <span class="float-social__toggle-close">
      <svg class="icon" width="20" height="20"><use href="#icon-close" /></svg>
    </span>
    <span class="float-social__badge"></span>
  </button>

  <div class="float-social__panel" aria-hidden="true">
    <div class="float-social__header">
      <p class="float-social__title">{{ settings.float_social_title | default: 'Liên hệ với chúng tôi' }}</p>
      <p class="float-social__subtitle">{{ settings.float_social_subtitle | default: 'Chọn kênh liên hệ bạn muốn' }}</p>
    </div>
    <ul class="float-social__list">
      {%- if settings.float_hotline_enable -%}
      <li class="float-social__item" style="--item-index: 0;">
        <a href="tel:{{ settings.float_hotline_link }}" class="float-social__link float-social__link--hotline" title="Hotline">
          <span class="float-social__icon">
            <img src="{{ 'float_hotline_image.png' | img_url: 'compact' | asset_url }}" alt="Hotline" width="28" height="28" loading="lazy">
          </span>
          <span class="float-social__text">{{ settings.float_hotline_text | default: 'Hotline' }}</span>
          <span class="float-social__arrow"><svg class="icon" width="14" height="14"><use href="#icon-chevron-right" /></svg></span>
        </a>
      </li>
      {%- endif -%}

      {%- if settings.float_zalo_enable -%}
      <li class="float-social__item" style="--item-index: 1;">
        <a href="{{ settings.float_zalo_link }}" class="float-social__link float-social__link--zalo" title="Zalo" target="_blank" rel="noopener noreferrer">
          <span class="float-social__icon">
            <img src="{{ 'float_zalo_image.png' | img_url: 'compact' | asset_url }}" alt="Zalo" width="28" height="28" loading="lazy">
          </span>
          <span class="float-social__text">{{ settings.float_zalo_text | default: 'Zalo' }}</span>
          <span class="float-social__arrow"><svg class="icon" width="14" height="14"><use href="#icon-chevron-right" /></svg></span>
        </a>
      </li>
      {%- endif -%}

      {%- if settings.float_facebook_enable -%}
      <li class="float-social__item" style="--item-index: 2;">
        <a href="{{ settings.float_facebook_link }}" class="float-social__link float-social__link--facebook" title="Facebook" target="_blank" rel="noopener noreferrer">
          <span class="float-social__icon">
            <img src="{{ 'float_facebook_image.png' | img_url: 'compact' | asset_url }}" alt="Facebook" width="28" height="28" loading="lazy">
          </span>
          <span class="float-social__text">{{ settings.float_facebook_text | default: 'Facebook' }}</span>
          <span class="float-social__arrow"><svg class="icon" width="14" height="14"><use href="#icon-chevron-right" /></svg></span>
        </a>
      </li>
      {%- endif -%}

      {%- if settings.float_messenger_enable -%}
      <li class="float-social__item" style="--item-index: 3;">
        <a href="{{ settings.float_messenger_link }}" class="float-social__link float-social__link--messenger" title="Messenger" target="_blank" rel="noopener noreferrer">
          <span class="float-social__icon">
            <img src="{{ 'float_messenger_image.png' | img_url: 'compact' | asset_url }}" alt="Messenger" width="28" height="28" loading="lazy">
          </span>
          <span class="float-social__text">{{ settings.float_messenger_text | default: 'Messenger' }}</span>
          <span class="float-social__arrow"><svg class="icon" width="14" height="14"><use href="#icon-chevron-right" /></svg></span>
        </a>
      </li>
      {%- endif -%}

      {%- if settings.float_tiktok_enable -%}
      <li class="float-social__item" style="--item-index: 4;">
        <a href="{{ settings.float_tiktok_link }}" class="float-social__link float-social__link--tiktok" title="TikTok" target="_blank" rel="noopener noreferrer">
          <span class="float-social__icon">
            <img src="{{ 'float_tiktok_image.png' | img_url: 'compact' | asset_url }}" alt="TikTok" width="28" height="28" loading="lazy">
          </span>
          <span class="float-social__text">{{ settings.float_tiktok_text | default: 'TikTok' }}</span>
          <span class="float-social__arrow"><svg class="icon" width="14" height="14"><use href="#icon-chevron-right" /></svg></span>
        </a>
      </li>
      {%- endif -%}

      {%- if settings.float_shopee_enable -%}
      <li class="float-social__item" style="--item-index: 5;">
        <a href="{{ settings.float_shopee_link }}" class="float-social__link float-social__link--shopee" title="Shopee" target="_blank" rel="noopener noreferrer">
          <span class="float-social__icon">
            <img src="{{ 'float_shopee_image.png' | img_url: 'compact' | asset_url }}" alt="Shopee" width="28" height="28" loading="lazy">
          </span>
          <span class="float-social__text">{{ settings.float_shopee_text | default: 'Shopee' }}</span>
          <span class="float-social__arrow"><svg class="icon" width="14" height="14"><use href="#icon-chevron-right" /></svg></span>
        </a>
      </li>
      {%- endif -%}

      {%- if settings.float_lazada_enable -%}
      <li class="float-social__item" style="--item-index: 6;">
        <a href="{{ settings.float_lazada_link }}" class="float-social__link float-social__link--lazada" title="Lazada" target="_blank" rel="noopener noreferrer">
          <span class="float-social__icon">
            <img src="{{ 'float_lazada_image.png' | img_url: 'compact' | asset_url }}" alt="Lazada" width="28" height="28" loading="lazy">
          </span>
          <span class="float-social__text">{{ settings.float_lazada_text | default: 'Lazada' }}</span>
          <span class="float-social__arrow"><svg class="icon" width="14" height="14"><use href="#icon-chevron-right" /></svg></span>
        </a>
      </li>
      {%- endif -%}

      {%- if settings.float_telegram_enable -%}
      <li class="float-social__item" style="--item-index: 7;">
        <a href="{{ settings.float_telegram_link }}" class="float-social__link float-social__link--telegram" title="Telegram" target="_blank" rel="noopener noreferrer">
          <span class="float-social__icon">
            <img src="{{ 'float_telegram_image.png' | img_url: 'compact' | asset_url }}" alt="Telegram" width="28" height="28" loading="lazy">
          </span>
          <span class="float-social__text">{{ settings.float_telegram_text | default: 'Telegram' }}</span>
          <span class="float-social__arrow"><svg class="icon" width="14" height="14"><use href="#icon-chevron-right" /></svg></span>
        </a>
      </li>
      {%- endif -%}

      {%- if settings.float_email_enable -%}
      <li class="float-social__item" style="--item-index: 8;">
        <a href="mailto:{{ settings.float_email_link | strip }}" class="float-social__link float-social__link--email" title="Email">
          <span class="float-social__icon">
            <img src="{{ 'float_email_image.png' | img_url: 'compact' | asset_url }}" alt="Email" width="28" height="28" loading="lazy">
          </span>
          <span class="float-social__text">{{ settings.float_email_text | default: 'Email' }}</span>
          <span class="float-social__arrow"><svg class="icon" width="14" height="14"><use href="#icon-chevron-right" /></svg></span>
        </a>
      </li>
      {%- endif -%}

      {%- if settings.float_map_enable -%}
      <li class="float-social__item" style="--item-index: 9;">
        <a href="{{ settings.float_map_link }}" class="float-social__link float-social__link--map" title="Bản đồ" target="_blank" rel="noopener noreferrer">
          <span class="float-social__icon">
            <img src="{{ 'float_map_image.png' | img_url: 'compact' | asset_url }}" alt="Bản đồ" width="28" height="28" loading="lazy">
          </span>
          <span class="float-social__text">{{ settings.float_map_text | default: 'Bản đồ' }}</span>
          <span class="float-social__arrow"><svg class="icon" width="14" height="14"><use href="#icon-chevron-right" /></svg></span>
        </a>
      </li>
      {%- endif -%}

      {%- if settings.float_instagram_enable -%}
      <li class="float-social__item" style="--item-index: 10;">
        <a href="{{ settings.float_instagram_link }}" class="float-social__link float-social__link--instagram" title="Instagram" target="_blank" rel="noopener noreferrer">
          <span class="float-social__icon">
            <img src="{{ 'float_instagram_image.png' | img_url: 'compact' | asset_url }}" alt="Instagram" width="28" height="28" loading="lazy">
          </span>
          <span class="float-social__text">{{ settings.float_instagram_text | default: 'Instagram' }}</span>
          <span class="float-social__arrow"><svg class="icon" width="14" height="14"><use href="#icon-chevron-right" /></svg></span>
        </a>
      </li> 
      {%- endif -%}

      {%- if settings.float_youtube_enable -%}
      <li class="float-social__item" style="--item-index: 11;">
        <a href="{{ settings.float_youtube_link }}" class="float-social__link float-social__link--youtube" title="YouTube" target="_blank" rel="noopener noreferrer">
          <span class="float-social__icon">
            <img src="{{ 'float_youtube_image.png' | img_url: 'compact' | asset_url }}" alt="YouTube" width="28" height="28" loading="lazy">
          </span>
          <span class="float-social__text">{{ settings.float_youtube_text | default: 'YouTube' }}</span>
          <span class="float-social__arrow"><svg class="icon" width="14" height="14"><use href="#icon-chevron-right" /></svg></span>
        </a>
      </li>
      {%- endif -%}
    </ul>
  </div>
</float-social>
{%- endif -%}
