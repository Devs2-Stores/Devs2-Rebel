<cart-total class="cart-total">
  <h4 class="cart-total__title">Tóm tắt đơn hàng</h4>
  <ul class="cart-total__list">
    <li>
      <span>Số sản phẩm:</span>
      <strong><span class="cart-count">{{ cart.item_count }}</span> sản phẩm</strong>
    </li>
    <li>
      <span>Tạm tính:</span>
      <strong class="cart-price">{%- if cart.total_price == 0 -%}Liên hệ{%- else -%}{{ cart.total_price | money }}{%- endif -%}</strong>
    </li>
    {%- if cart.total_discount > 0 -%}
    <li class="cart-total__discount">
      <span>Giảm giá:</span>
      <strong>-{{ cart.total_discount | money }}</strong>
    </li>
    {%- endif -%}
    <li>
      <span>Phí vận chuyển:</span>
      <strong>Được tính ở bước sau</strong>
    </li>
  </ul>
  <div class="cart-total__actions">
    {%- if cart.total_price > 0 -%}
    <a href="/checkout" class="button-primary active">Thanh toán</a>
    {%- endif -%}
    <a href="/collections/all" class="button-primary">Tiếp tục mua sắm</a>
  </div>
</cart-total>