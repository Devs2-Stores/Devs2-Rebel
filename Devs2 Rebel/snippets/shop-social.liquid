		<a href="{{ settings.linkLinkedinsocial }}" class="shop-social__link shop-social__link--linkedin" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn {{ shop.name }}" title="Theo dõi trên LinkedIn">
			{%- include 'icon' with name: 'linkedin' -%}
		</a>
	</li>
	{%- endif -%}
</ul>