<ul class="shop-social">
	{%- if settings.linkFbsocial != blank -%}
	<li class="shop-social__item">
		<a href="{{ settings.linkFbsocial }}" class="shop-social__link shop-social__link--facebook" target="_blank" rel="noopener noreferrer" aria-label="Facebook {{ shop.name }}" title="Theo dõi trên Facebook">
			{%- include 'icon' with name: 'facebook' -%}
		</a>
	</li>
	{%- endif -%}

	{%- if settings.linkInsocial != blank -%}
	<li class="shop-social__item">
		<a href="{{ settings.linkInsocial }}" class="shop-social__link shop-social__link--instagram" target="_blank" rel="noopener noreferrer" aria-label="Instagram {{ shop.name }}" title="Theo dõi trên Instagram">
			{%- include 'icon' with name: 'instagram' -%}
		</a>
	</li>
	{%- endif -%}

	{%- if settings.linkYtsocial != blank -%}
