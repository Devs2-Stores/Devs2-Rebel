		<a href="{{ settings.linkYtsocial }}" class="shop-social__link shop-social__link--youtube" target="_blank" rel="noopener noreferrer" aria-label="Youtube {{ shop.name }}" title="Theo dõi trên Youtube">
			{%- include 'icon' with name: 'youtube' -%}
		</a>
	</li>
	{%- endif -%}

	{%- if settings.linkTwsocial != blank -%}
