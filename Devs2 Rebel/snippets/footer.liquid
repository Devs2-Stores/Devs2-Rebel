<global-footer class="footer">
  <div class="page-width">
    <div class="footer-wrapper">
      <div class="footer-info">
        <div class="footer-info__logo">
          <a href="/" title="{{ shop.name | escape }}" class="footer-logo">
            <img src="{{ 'footers2_one_logo.png' | asset_url }}" alt="{{ shop.name | escape }}" width="200" height="60" class="footer-logo__image" loading="lazy" decoding="async">
          </a>
        </div>
        <div class="footer-info__description">
          <p class="footer-info__description-text">{{ settings.footer_description }}</p>
        </div>
        <div class="footer-info__social-media">
          {%- if settings.footer_social_facebook != blank -%}
          <a href="{{ settings.footer_social_facebook }}" title="Facebook" aria-label="Facebook" class="footer-social-media__link" target="_blank" rel="noopener noreferrer">
            {%- include 'icon' with name: 'facebook', class: 'icon-facebook' -%}
          </a>
          {%- endif -%}
          {%- if settings.footer_social_instagram != blank -%}
          <a href="{{ settings.footer_social_instagram }}" title="Instagram" aria-label="Instagram" class="footer-social-media__link" target="_blank" rel="noopener noreferrer">
            {%- include 'icon' with name: 'instagram', class: 'icon-instagram' -%}
          </a>
          {%- endif -%}
          {%- if settings.footer_social_twitter != blank -%}
          <a href="{{ settings.footer_social_twitter }}" title="Twitter / X" aria-label="Twitter" class="footer-social-media__link" target="_blank" rel="noopener noreferrer">
            {%- include 'icon' with name: 'twitter' -%}
          </a>
          {%- endif -%}
          {%- if settings.footer_social_tiktok != blank -%}
          <a href="{{ settings.footer_social_tiktok }}" title="Tiktok" aria-label="Tiktok" class="footer-social-media__link" target="_blank" rel="noopener noreferrer">
            {%- include 'icon' with name: 'tiktok' -%}
          </a>
          {%- endif -%}
          {%- if settings.footer_social_youtube != blank -%}
          <a href="{{ settings.footer_social_youtube }}" title="YouTube" aria-label="YouTube" class="footer-social-media__link" target="_blank" rel="noopener noreferrer">
            {%- include 'icon' with name: 'youtube' -%}
          </a>
          {%- endif -%}
        </div>
        {%- if settings.footer_zalo_enable -%}
        <div class="footer-info__zalo-miniapp">
          <div class="footer-info__zalo-miniapp-media">
            <img src="{{ 'footer_zalo_qr.png' | asset_url }}" alt="Zalo Mini App QR" width="120" height="120" class="footer-info__zalo-miniapp-qr" loading="lazy" decoding="async">
          </div>
          <div class="footer-info__zalo-miniapp-text">
            {%- if settings.footer_zalo_title != blank -%}
            <p class="footer-info__zalo-miniapp-title">{{ settings.footer_zalo_title }}</p>
            {%- endif -%}
            {%- if settings.footer_zalo_description != blank -%}
            <p class="footer-info__zalo-miniapp-desc">{{ settings.footer_zalo_description }}</p>
            {%- endif -%}
          </div>
        </div>
        {%- endif -%}
        {%- if settings.footer_certs_enable -%}
        <div class="footer-info__certs">
          <a href="{{ settings.footer_cert_bct_link }}" title="Bộ Công Thương" aria-label="Bộ Công Thương" class="footer-info__cert-item" target="_blank" rel="noopener noreferrer">
            <img src="{{ 'footer_cert_bct.png' | asset_url }}" alt="Bộ Công Thương" width="130" height="50" class="footer-info__cert-img" loading="lazy" decoding="async">
          </a>
          <a href="{{ settings.footer_cert_dmca_link }}" title="DMCA" aria-label="DMCA" class="footer-info__cert-item" target="_blank" rel="noopener noreferrer">
            <img src="{{ 'footer_cert_dmca.png' | asset_url }}" alt="DMCA" width="130" height="50" class="footer-info__cert-img" loading="lazy" decoding="async">
          </a>
        </div>
        {%- endif -%}
      </div>
      <div class="footer-actions">
        <div class="footer_actions__slogan">
          <h3 class="footer_actions_slogan-title">{{ settings.footer_newsletter_title }}</h3>
        </div>
        <div class="footer-actions-menus">
          {%- for i in (1..4) -%}
          {%- capture menu_enable -%}footer_menu_enable_{{ i }}{%- endcapture -%}
          {%- capture menu_title -%}footer_menu_title_{{ i }}{%- endcapture -%}
          {%- capture menu_key -%}footer_menu_{{ i }}{%- endcapture -%}
          {%- assign menu_handle = settings[menu_key] -%}
          {%- if settings[menu_enable] -%}
          <div class="footer-actions-menu">
            <h3 class="footer-actions-menu__title">{{ settings[menu_title] }}</h3>
            <ul class="footer-actions-menu__list">
              {%- assign menu = linklists[menu_handle] -%}
              {%- if menu_handle != blank and menu.links != blank -%}
              {%- for link in menu.links -%}
              <li>
                <a title="{{ link.title | escape }}" href="{{ link.url }}">{{ link.title }}</a>
              </li>
              {%- endfor -%}
              {%- else -%}
              <li>Đang cập nhật</li>
              {%- endif -%}
            </ul>
          </div>
          {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
    <div class="footer-copyright">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name | link_to: '/' -}}, {{ powered_by_link }}</p>

      <div class="footer-contact">
        {%- if settings.footer_address != blank -%}
        <span class="footer-contact__item">{{ settings.footer_address }}</span>
        {%- endif -%}
        {%- if settings.footer_email != blank -%}
        <span class="footer-contact__item"><a href="mailto:{{ settings.footer_email }}">{{ settings.footer_email }}</a></span>
        {%- endif -%}
        {%- if settings.footer_phone != blank -%}
        <span class="footer-contact__item"><a href="tel:{{ settings.footer_phone }}">{{ settings.footer_phone }}</a></span>
        {%- endif -%}
        {%- if settings.footer_tax_code != blank -%}
        <span class="footer-contact__item">{{ settings.footer_tax_code }}</span>
        {%- endif -%}
      </div>
    </div>
  </div>
</global-footer>
