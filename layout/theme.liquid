<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    {%- render 'head-meta-tags' -%}
    {%- render 'head-fonts' -%}
    {%- render 'head-stylesheets' -%}
    {%- render 'head-color-schemes' -%}
    {%- render 'head-design-systems' -%}
    {%- render 'head-script' -%}
    {%- render 'head-defer' -%}
    {{ content_for_header }}
  </head>

  <body class="gradient{% if settings.animations_reveal_on_scroll %} animate--enabled{% endif %}">
    {%- render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' | t -%}
    {%- render 'icons-sprite' -%}

    {%- sections 'header-group' -%}
    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>
    {%- sections 'footer-group' -%}

    {%- render 'newsletter-modal' -%}
    {%- render 'cart-modal' -%}
    {%- render 'search-modal' -%}
    {%- render 'quickview-modal' -%}
    {%- render 'mobile-menu' -%}
    {%- render 'float-social' -%}
    {{ 'toast.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'toast.js' | asset_url }}" defer="defer"></script>
    <div class="toast-container" role="status" aria-live="polite" aria-atomic="true"></div>
    <div class="overlay"></div>
    {{ 'back-to-top.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'back-to-top.js' | asset_url }}" defer="defer"></script>
    <button type="button" class="back-to-top" id="backToTop" aria-label="{{ 'accessibility.back_to_top' | t }}" aria-hidden="true">
      <svg class="icon" width="18" height="18">
        <use href="#icon-chevron-right" />
      </svg>
    </button>
    <wishlist-manager></wishlist-manager>

    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
      <li id="a11y-new-window-message">{{ 'accessibility.link_messages.new_window' | t }}</li>
    </ul>
  </body>
</html>
