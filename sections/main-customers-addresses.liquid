            </div>
          </label>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="new_country">
              <span class="required">{{ 'customer.addresses.country' | t }}</span>
              <div class="form-group-input">
                {%- render 'icon', name: 'location' -%}
                <select name="address[country]" id="new_country" class="form-control" data-default="{{ form.country }}">
                  <option value="" disabled selected>{{ 'customer.addresses.country' | t }}</option>
                  {{ country_option_tags }}
                </select>
              </div>
            </label>
          </div>
          <div class="form-group">
            <label for="new_province">
              <span>{{ 'customer.addresses.province' | t }}</span>
              <div class="form-group-input">
                {%- render 'icon', name: 'location' -%}
                <select name="address[province]" id="new_province" class="form-control" data-default="{{ form.province }}">
                  <option value="" disabled selected>{{ 'customer.addresses.province' | t }}</option>
                </select>
              </div>
            </label>
          </div>
        </div>
        <div class="form-group">
          <label for="new_zip">
            <span>{{ 'customer.addresses.zip' | t }}</span>
            <div class="form-group-input">
              {%- render 'icon', name: 'location' -%}
              <input type="text" name="address[zip]" id="new_zip" placeholder="{{ 'customer.addresses.zip' | t }}" value="{{ form.zip }}" class="form-control">
            </div>
          </label>
        </div>
        <div class="form-group">
          <label class="form-checkbox">
            <input type="checkbox" name="address[default]" id="new_is_default" value="true">
            <span>{{ 'customer.addresses.set_default' | t }}</span>
          </label>
        </div>
      </div>
    </div>
    <div class="address-modal-footer">
      <button type="button" class="button-primary" data-action="close-address-modal">{{ 'customer.addresses.cancel' | t }}</button>
      <button type="submit" title="{{ 'customer.addresses.add_new' | t }}" class="button-primary active">{{ 'customer.addresses.add_new' | t }}</button>
    </div>
    {%- endform -%}
  </div>
</address-modal>

{% schema %}
{
  "name": "t:sections.main_customers_addresses.name",
  "tag": "section",
  "class": "section-main-customers-addresses",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    }
  ]
}
{% endschema %}