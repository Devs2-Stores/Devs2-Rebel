{%- comment -%}
  Breadcrumb Section — standalone, can be added to any page via JSON template.
  Auto-detects page type via `template` and renders appropriate breadcrumb trail.
  Includes Schema.org BreadcrumbList structured data for SEO.
{%- endcomment -%}

{%- liquid
  assign t_home = 'general.breadcrumbs.home' | t
  assign t_all_products = 'general.breadcrumbs.all_products' | t
  assign t_tags = 'general.breadcrumbs.tags' | t
  assign t_not_found = 'general.breadcrumbs.not_found' | t
  assign t_cart = 'general.breadcrumbs.cart' | t
  assign t_search = 'general.breadcrumbs.search' | t
  assign t_login = 'general.breadcrumbs.login' | t
  assign t_register = 'general.breadcrumbs.register' | t
  assign t_account = 'general.breadcrumbs.account' | t
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .section-breadcrumbs {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    font-size: var(--font-{{ section.settings.font_size }});
  }
  #shopify-section-{{ section.id }} .breadcrumb {
    justify-content: {% if section.settings.text_alignment == 'center' %}center{% elsif section.settings.text_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
  }
{%- endstyle -%}

{%- unless template == 'index' -%}
{{ 'breadcrumb.css' | asset_url | stylesheet_tag }}
<div class="section-breadcrumbs">
  <div class="{% if section.settings.container_width == 'fixed' %}page-width{% endif %}">
    <nav class="breadcrumb-nav" aria-label="{{ 'general.breadcrumbs.aria_label' | t }}">
      <ol class="breadcrumb" itemscope itemtype="https://schema.org/BreadcrumbList">
        {%- comment -%} Home {%- endcomment -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a itemprop="item" href="{{ routes.root_url }}" class="breadcrumb__link" title="{{ t_home }}">
            <span itemprop="name">{{ t_home }}</span>
          </a>
          <meta itemprop="position" content="1">
        </li>

        {%- if template contains 'list-collections' -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">{{ section.settings.separator }}</span>
          <span itemprop="name">{{ page_title }}</span>
          <meta itemprop="position" content="2">
        </li>

        {%- elsif template contains 'collection' and collection -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">{{ section.settings.separator }}</span>
          <span itemprop="name">
            {%- if collection.handle == 'all' -%}{{ t_all_products }}{%- else -%}{{ collection.title }}{%- endif -%}
          </span>
          <meta itemprop="position" content="2">
        </li>
        {%- if current_tags.size > 0 -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">{{ section.settings.separator }}</span>
          <span itemprop="name">{{ t_tags }}: <strong>{{ current_tags | join: ', ' }}</strong></span>
          <meta itemprop="position" content="3">
        </li>
        {%- endif -%}

        {%- elsif template contains 'product' and product -%}
        {%- liquid
          assign product_collection = product.collections | first
          assign bc_collection_title = t_all_products
          assign bc_collection_url = routes.all_products_collection_url | default: '/collections/all'
          if product_collection
            assign bc_collection_title = product_collection.title
            assign bc_collection_url = product_collection.url
          endif
        -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">{{ section.settings.separator }}</span>
          <a class="breadcrumb__link" itemprop="item" href="{{ bc_collection_url }}">
            <span itemprop="name">{{ bc_collection_title }}</span>
          </a>
          <meta itemprop="position" content="2">
        </li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">{{ section.settings.separator }}</span>
          <span itemprop="name">{{ product.title | escape }}</span>
          <meta itemprop="position" content="3">
        </li>

        {%- elsif template contains 'blog' and blog -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">{{ section.settings.separator }}</span>
          <span itemprop="name">{{ blog.title }}</span>
          <meta itemprop="position" content="2">
        </li>

        {%- elsif template contains 'article' and article -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">{{ section.settings.separator }}</span>
          <a itemprop="item" href="{{ blog.url }}" class="breadcrumb__link">
            <span itemprop="name">{{ blog.title }}</span>
          </a>
          <meta itemprop="position" content="2">
        </li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">{{ section.settings.separator }}</span>
          <span itemprop="name">{{ article.title }}</span>
          <meta itemprop="position" content="3">
        </li>

        {%- elsif template contains 'page' and page -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">{{ section.settings.separator }}</span>
          <span itemprop="name">{{ page.title }}</span>
          <meta itemprop="position" content="2">
        </li>

        {%- elsif template contains 'cart' -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">{{ section.settings.separator }}</span>
          <span itemprop="name">{{ t_cart }}</span>
          <meta itemprop="position" content="2">
        </li>

        {%- elsif template contains 'search' -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">{{ section.settings.separator }}</span>
          <span itemprop="name">{{ t_search }}</span>
          <meta itemprop="position" content="2">
        </li>

        {%- elsif template contains '404' -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">{{ section.settings.separator }}</span>
          <span itemprop="name">{{ t_not_found }}</span>
          <meta itemprop="position" content="2">
        </li>

        {%- elsif template contains 'customers' -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">{{ section.settings.separator }}</span>
          <span itemprop="name">
            {%- if template contains 'login' -%}{{ t_login }}
            {%- elsif template contains 'register' -%}{{ t_register }}
            {%- else -%}{{ t_account }}
            {%- endif -%}
          </span>
          <meta itemprop="position" content="2">
        </li>
        {%- endif -%}
      </ol>
    </nav>
  </div>
</div>
{%- endunless -%}

{% schema %}
{
  "name": "t:sections.breadcrumb.name",
  "tag": "section",
  "class": "section-breadcrumb",
  "settings": [
    {
      "type": "select",
      "id": "container_width",
      "label": "t:sections.all.container_width.label",
      "options": [
        {
          "value": "full",
          "label": "t:sections.all.container_width.options__full.label"
        },
        {
          "value": "fixed",
          "label": "t:sections.all.container_width.options__fixed.label"
        }
      ],
      "default": "fixed"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "t:sections.all.text_alignment.label",
      "options": [
        {
          "value": "left",
          "label": "t:sections.all.text_alignment.options__left.label"
        },
        {
          "value": "center",
          "label": "t:sections.all.text_alignment.options__center.label"
        },
        {
          "value": "right",
          "label": "t:sections.all.text_alignment.options__right.label"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "font_size",
      "label": "t:sections.breadcrumb.settings.font_size.label",
      "options": [
        {
          "value": "xs",
          "label": "t:sections.breadcrumb.settings.font_size.options__xs.label"
        },
        {
          "value": "sm",
          "label": "t:sections.breadcrumb.settings.font_size.options__sm.label"
        },
        {
          "value": "base",
          "label": "t:sections.breadcrumb.settings.font_size.options__base.label"
        }
      ],
      "default": "sm"
    },
    {
      "type": "text",
      "id": "separator",
      "label": "t:sections.breadcrumb.settings.separator.label",
      "default": "/"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Breadcrumb"
    }
  ]
}
{% endschema %}