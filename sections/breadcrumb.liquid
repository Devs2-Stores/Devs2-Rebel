{%- comment -%}
  Breadcrumb Section — standalone, can be added to any page via JSON template.
  Auto-detects page type via `template` and renders appropriate breadcrumb trail.
  Includes Schema.org BreadcrumbList structured data for SEO.
{%- endcomment -%}

{%- liquid
  assign t_home = 'general.breadcrumbs.home' | t | default: 'Home'
  assign t_all_products = 'general.breadcrumbs.all_products' | t | default: 'All Products'
  assign t_all_posts = 'general.breadcrumbs.all_posts' | t | default: 'All Posts'
  assign t_tags = 'general.breadcrumbs.tags' | t | default: 'Tags'
  assign t_not_found = 'general.breadcrumbs.not_found' | t | default: 'Page not found'
  assign t_cart = 'general.breadcrumbs.cart' | t | default: 'Cart'
  assign t_search = 'general.breadcrumbs.search' | t | default: 'Search'
  assign t_login = 'general.breadcrumbs.login' | t | default: 'Log in'
  assign t_register = 'general.breadcrumbs.register' | t | default: 'Create account'
  assign t_account = 'general.breadcrumbs.account' | t | default: 'Account'
  assign t_wishlist = 'general.breadcrumbs.wishlist' | t | default: 'Wishlist'
-%}

{%- unless template == 'index' -%}
<div class="section-breadcrumbs">
  <div class="page-width">
    <nav class="breadcrumb-nav" aria-label="{{ 'general.breadcrumbs.aria_label' | t | default: 'Breadcrumbs' }}">
      <ol class="breadcrumb" itemscope itemtype="https://schema.org/BreadcrumbList">
        {%- comment -%} Home {%- endcomment -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a itemprop="item" href="{{ routes.root_url }}" class="breadcrumb__link" title="{{ t_home }}">
            <span itemprop="name">{{ t_home }}</span>
          </a>
          <meta itemprop="position" content="1">
        </li>

        {%- if template contains 'list-collections' -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">/</span>
          <span itemprop="name">{{ page_title }}</span>
          <meta itemprop="position" content="2">
        </li>

        {%- elsif template contains 'collection' and collection -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">/</span>
          <span itemprop="name">
            {%- if collection.handle == 'all' -%}{{ t_all_products }}{%- else -%}{{ collection.title }}{%- endif -%}
          </span>
          <meta itemprop="position" content="2">
        </li>
        {%- if current_tags.size > 0 -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">/</span>
          <span itemprop="name">{{ t_tags }}: <strong>{{ current_tags | join: ', ' }}</strong></span>
          <meta itemprop="position" content="3">
        </li>
        {%- endif -%}

        {%- elsif template contains 'product' and product -%}
        {%- liquid
          assign product_collection = product.collections | first
          assign bc_collection_title = t_all_products
          assign bc_collection_url = routes.all_products_collection_url | default: '/collections/all'
          if product_collection
            assign bc_collection_title = product_collection.title
            assign bc_collection_url = product_collection.url
          endif
        -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">/</span>
          <a class="breadcrumb__link" itemprop="item" href="{{ bc_collection_url }}">
            <span itemprop="name">{{ bc_collection_title }}</span>
          </a>
          <meta itemprop="position" content="2">
        </li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">/</span>
          <span itemprop="name">{{ product.title | escape }}</span>
          <meta itemprop="position" content="3">
        </li>

        {%- elsif template contains 'blog' and blog -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">/</span>
          <span itemprop="name">{{ blog.title }}</span>
          <meta itemprop="position" content="2">
        </li>

        {%- elsif template contains 'article' and article -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">/</span>
          <a itemprop="item" href="{{ blog.url }}" class="breadcrumb__link">
            <span itemprop="name">{{ blog.title }}</span>
          </a>
          <meta itemprop="position" content="2">
        </li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">/</span>
          <span itemprop="name">{{ article.title }}</span>
          <meta itemprop="position" content="3">
        </li>

        {%- elsif template contains 'page' and page -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">/</span>
          <span itemprop="name">{{ page.title }}</span>
          <meta itemprop="position" content="2">
        </li>

        {%- elsif template contains 'cart' -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">/</span>
          <span itemprop="name">{{ t_cart }}</span>
          <meta itemprop="position" content="2">
        </li>

        {%- elsif template contains 'search' -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">/</span>
          <span itemprop="name">{{ t_search }}</span>
          <meta itemprop="position" content="2">
        </li>

        {%- elsif template contains '404' -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">/</span>
          <span itemprop="name">{{ t_not_found }}</span>
          <meta itemprop="position" content="2">
        </li>

        {%- elsif template contains 'customers' -%}
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="breadcrumb__separator" aria-hidden="true">/</span>
          <span itemprop="name">
            {%- if template contains 'login' -%}{{ t_login }}
            {%- elsif template contains 'register' -%}{{ t_register }}
            {%- else -%}{{ t_account }}
            {%- endif -%}
          </span>
          <meta itemprop="position" content="2">
        </li>
        {%- endif -%}
      </ol>
    </nav>
  </div>
</div>
{%- endunless -%}

{% schema %}
{
  "name": "Breadcrumb",
  "tag": "section",
  "class": "section-breadcrumb",
  "settings": [],
  "presets": [
    {
      "name": "Breadcrumb"
    }
  ]
}
{% endschema %}