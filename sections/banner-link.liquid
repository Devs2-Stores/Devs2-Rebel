{%- comment -%}
  Banner Link Section — Simple banner image with optional link.
  Supports separate desktop/mobile images.
  Can be added to any page template.
{%- endcomment -%}

{{ 'banner-link.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign desktop_image = section.settings.image_desktop
  assign mobile_image = section.settings.image_mobile | default: desktop_image
  assign link = section.settings.link
  assign image_alt = desktop_image.alt | default: section.settings.alt_text | default: 'Banner'
  assign mobile_alt = mobile_image.alt | default: image_alt
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .section-banner-link {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

{%- if desktop_image -%}
<div class="section-banner-link">
  <div class="{% if section.settings.container_width == 'fixed' %}page-width{% endif %}">
    {%- if link != blank -%}
      <a href="{{ link }}" class="banner-link__wrapper" aria-label="{{ image_alt }}">
    {%- else -%}
      <div class="banner-link__wrapper">
    {%- endif -%}

      {%- comment -%} Desktop Image {%- endcomment -%}
      <div class="banner-link__desktop">
        {{ desktop_image | image_url: width: 1920 | image_tag:
          widths: '750, 1080, 1440, 1920',
          sizes: '100vw',
          alt: image_alt,
          loading: 'lazy',
          decoding: 'async',
          class: 'banner-link__img'
        }}
      </div>

      {%- comment -%} Mobile Image {%- endcomment -%}
      <div class="banner-link__mobile">
        {{ mobile_image | image_url: width: 750 | image_tag:
          widths: '375, 550, 750',
          sizes: '100vw',
          alt: mobile_alt,
          loading: 'lazy',
          decoding: 'async',
          class: 'banner-link__img'
        }}
      </div>

    {%- if link != blank -%}
      </a>
    {%- else -%}
      </div>
    {%- endif -%}
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.banner_link.name",
  "tag": "section",
  "class": "section-banner-link-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.banner_link.settings.header__images.content"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "t:sections.banner_link.settings.image_desktop.label"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "t:sections.banner_link.settings.image_mobile.label",
      "info": "t:sections.banner_link.settings.image_mobile.info"
    },
    {
      "type": "text",
      "id": "alt_text",
      "label": "t:sections.banner_link.settings.alt_text.label",
      "info": "t:sections.banner_link.settings.alt_text.info"
    },
    {
      "type": "header",
      "content": "t:sections.banner_link.settings.header__link.content"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:sections.banner_link.settings.link.label"
    },
    {
      "type": "header",
      "content": "t:sections.banner_link.settings.header__layout.content"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "t:sections.all.container_width.label",
      "options": [
        {
          "value": "full",
          "label": "t:sections.all.container_width.options__full.label"
        },
        {
          "value": "fixed",
          "label": "t:sections.all.container_width.options__fixed.label"
        }
      ],
      "default": "full"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Banner link"
    }
  ]
}
{% endschema %}
