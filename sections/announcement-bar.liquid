{%- if section.settings.enable -%}
<announcement-bar class="announcement-bar color-{{ section.settings.color_scheme }}" role="region" aria-label="{{ 'sections.announcement_bar.label' | t }}">
  <div class="announcement-bar__container">
    <div class="swiper announcement-bar__swiper">
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
        <div class="swiper-slide announcement-bar__slide" {{ block.shopify_attributes }}>
          <div class="announcement-bar__content">
            {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="announcement-bar__text announcement-bar__link">{{ block.settings.text }}</a>
            {%- else -%}
            <span class="announcement-bar__text">{{ block.settings.text }}</span>
            {%- endif -%}
          </div>
        </div>
        {%- endfor -%}
      </div>
    </div>
    {%- if section.blocks.size > 1 -%}
    <button type="button" class="announcement-bar__nav announcement-bar__nav--prev swiper-button-prev" aria-label="{{ 'accessibility.previous' | t }}"></button>
    <button type="button" class="announcement-bar__nav announcement-bar__nav--next swiper-button-next" aria-label="{{ 'accessibility.next' | t }}"></button>
    {%- endif -%}
  </div>
</announcement-bar>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.announcement_bar.name",
  "tag": "section",
  "class": "announcement-bar-section",
  "limit": 1,
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "t:sections.announcement_bar.settings.enable.label",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "t:sections.announcement_bar.blocks.announcement.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "t:sections.announcement_bar.blocks.announcement.settings.text.label",
          "default": "Welcome to our store"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.announcement_bar.blocks.announcement.settings.link.label"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "announcement" }
    ]
  },
  "enabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}