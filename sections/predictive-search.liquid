{%- layout none -%}
{%- comment -%}
  Predictive Search Section
  Renders search suggestions using Shopify's predictive_search object.
  Called via Section Rendering API: /search/suggest?section_id=predictive-search&q=...
{%- endcomment -%}

{%- if predictive_search.performed -%}
<div id="predictive-search-results">

  {%- if predictive_search.resources.queries.size > 0 -%}
  <div class="predictive-search__group">
    <h3 class="predictive-search__group-title" id="ps-queries">
      {{ 'templates.search.suggestions' | t }}
    </h3>
    <ul class="predictive-search__list" role="group" aria-labelledby="ps-queries">
      {%- for query in predictive_search.resources.queries -%}
      <li class="predictive-search__item" role="option">
        <a href="{{ query.url }}" class="predictive-search__link predictive-search__link--query">
          {%- render 'icon', name: 'search' -%}
          <span>{{ query.styled_text }}</span>
        </a>
      </li>
      {%- endfor -%}
    </ul>
  </div>
  {%- endif -%}

  {%- if predictive_search.resources.products.size > 0 -%}
  <div class="predictive-search__group">
    <h3 class="predictive-search__group-title" id="ps-products">
      {{ 'templates.search.products' | t }}
    </h3>
    <ul class="predictive-search__list predictive-search__list--products" role="group" aria-labelledby="ps-products">
      {%- for product in predictive_search.resources.products -%}
      <li class="predictive-search__item" role="option">
        <a href="{{ product.url }}" class="predictive-search__link predictive-search__link--product">
          <div class="predictive-search__product-image">
            {%- if product.featured_image != blank -%}
              {%- assign ps_product_alt = product.featured_image.alt | default: product.title | escape -%}
              {{ product.featured_image | image_url: width: 150 | image_tag:
                loading: 'lazy',
                alt: ps_product_alt,
                class: 'predictive-search__img'
              }}
            {%- else -%}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" aria-hidden="true" width="40" height="40" style="opacity:.3">
                <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A1.5 1.5 0 0 0 21.75 19.5V4.5A1.5 1.5 0 0 0 20.25 3H3.75A1.5 1.5 0 0 0 2.25 4.5v15A1.5 1.5 0 0 0 3.75 21Z" />
              </svg>
            {%- endif -%}
          </div>
          <div class="predictive-search__product-info">
            <span class="predictive-search__product-title">{{ product.title }}</span>
            {%- if settings.predictive_search_show_vendor and product.vendor != blank -%}
            <span class="predictive-search__product-vendor">{{ product.vendor }}</span>
            {%- endif -%}
            {%- if settings.predictive_search_show_price -%}
            <span class="predictive-search__product-price">
              {%- if product.price == 0 -%}
                {{ 'products.product.price.contact' | t }}
              {%- else -%}
                {{ product.price | money }}
                {%- if product.compare_at_price > product.price -%}
                <del class="predictive-search__product-compare-price">{{ product.compare_at_price | money }}</del>
                {%- endif -%}
              {%- endif -%}
            </span>
            {%- endif -%}
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="predictive-search__arrow" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
          </svg>
        </a>
      </li>
      {%- endfor -%}
    </ul>
  </div>
  {%- endif -%}

  {%- if predictive_search.resources.collections.size > 0 -%}
  <div class="predictive-search__group">
    <h3 class="predictive-search__group-title" id="ps-collections">
      {{ 'templates.search.collections' | t }}
    </h3>
    <ul class="predictive-search__list" role="group" aria-labelledby="ps-collections">
      {%- for collection in predictive_search.resources.collections -%}
      <li class="predictive-search__item" role="option">
        <a href="{{ collection.url }}" class="predictive-search__link predictive-search__link--collection">
          {%- if collection.featured_image != blank -%}
          <div class="predictive-search__collection-image">
            {%- assign ps_col_alt = collection.title | escape -%}
            {{ collection.featured_image | image_url: width: 80 | image_tag:
              loading: 'lazy',
              alt: ps_col_alt,
              class: 'predictive-search__img'
            }}
          </div>
          {%- endif -%}
          <span>{{ collection.title }}</span>
        </a>
      </li>
      {%- endfor -%}
    </ul>
  </div>
  {%- endif -%}

  {%- if predictive_search.resources.articles.size > 0 -%}
  <div class="predictive-search__group">
    <h3 class="predictive-search__group-title" id="ps-articles">
      {{ 'templates.search.pages' | t }}
    </h3>
    <ul class="predictive-search__list" role="group" aria-labelledby="ps-articles">
      {%- for article in predictive_search.resources.articles -%}
      <li class="predictive-search__item" role="option">
        <a href="{{ article.url }}" class="predictive-search__link predictive-search__link--article">
          <span>{{ article.title }}</span>
        </a>
      </li>
      {%- endfor -%}
    </ul>
  </div>
  {%- endif -%}

  {%- liquid
    assign total = predictive_search.resources.products.size | plus: predictive_search.resources.collections.size | plus: predictive_search.resources.articles.size | plus: predictive_search.resources.queries.size
  -%}
  {%- if total == 0 -%}
  <div class="predictive-search__no-results">
    <p>{{ 'templates.search.no_results_title' | t }}</p>
  </div>
  {%- endif -%}

</div>

<span class="predictive-search__status sr-only" role="status" aria-live="polite">
  {%- liquid
    assign total_results = predictive_search.resources.products.size | plus: predictive_search.resources.collections.size | plus: predictive_search.resources.articles.size
    if total_results > 0
      echo 'templates.search.results_count' | t: count: total_results
    else
      echo 'templates.search.no_results_title' | t
    endif
  -%}
</span>
{%- endif -%}
