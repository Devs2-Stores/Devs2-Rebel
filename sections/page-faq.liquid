
<faq-page class="page-faq">
  <section class="faq-hero">
    <div class="page-width">
      <div class="faq-hero__wrap">
        <h1 class="faq-hero__title">{{ section.settings.title | default: 'sections.page_faq.default_title' | t }}</h1>
        {%- if section.settings.description != blank -%}
        <p class="faq-hero__description">{{ section.settings.description }}</p>
        {%- endif -%}
        <div class="faq-hero__search">
          <label for="faq-search" class="sr-only">{{ 'sections.page_faq.search_label' | t }}</label>
          <div class="faq-hero__search-box">
            {%- render 'icon', name: 'search', size: '20' -%}
            <input type="text" id="faq-search" class="faq-hero__search-input" placeholder="{{ 'sections.page_faq.search_placeholder' | t }}" autocomplete="off">
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="faq-main section-padding">
    <div class="page-width">
      <div class="faq-main__wrap">
        {%- assign faq_groups = section.blocks | where: 'type', 'group' -%}
        {%- assign faq_items = section.blocks | where: 'type', 'question' -%}

        {%- for group in faq_groups -%}
        <div class="faq-group" data-faq-group="{{ forloop.index }}" {{ group.shopify_attributes }}>
          <h2 class="faq-group__title">
            {%- render 'icon', name: 'tag', size: '20' -%}
            {{ group.settings.title }}
          </h2>
          <div class="faq-group__items">
            {%- for item in faq_items -%}
            {%- if item.settings.group == group.id -%}
            <details class="faq-item" data-faq-question="{{ item.settings.question | escape }}" {{ item.shopify_attributes }}>
              <summary class="faq-item__question">
                <span class="faq-item__question-text">{{ item.settings.question }}</span>
                <span class="faq-item__icon">
                  {%- render 'icon', name: 'chevron-down', size: '20' -%}
                </span>
              </summary>
              <div class="faq-item__answer">
                {{ item.settings.answer }}
              </div>
            </details>
            {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
        {%- endfor -%}

        {%- comment -%} Ungrouped questions {%- endcomment -%}
        {%- for item in faq_items -%}
        {%- if item.settings.group == blank -%}
        <details class="faq-item" data-faq-question="{{ item.settings.question | escape }}" {{ item.shopify_attributes }}>
          <summary class="faq-item__question">
            <span class="faq-item__question-text">{{ item.settings.question }}</span>
            <span class="faq-item__icon">
              {%- render 'icon', name: 'chevron-down', size: '20' -%}
            </span>
          </summary>
          <div class="faq-item__answer">
            {{ item.settings.answer }}
          </div>
        </details>
        {%- endif -%}
        {%- endfor -%}

        <div class="faq-empty" id="faq-empty" style="display: none;">
          {%- render 'icon', name: 'sad', size: '48' -%}
          <p>{{ 'sections.page_faq.no_results' | t }}</p>
        </div>
      </div>
    </div>
  </section>

  {%- if section.settings.show_contact -%}
  <section class="faq-contact section-padding-bg">
    <div class="page-width">
      <div class="faq-contact__wrap">
        <h2 class="faq-contact__title">{{ section.settings.contact_title | default: 'sections.page_faq.need_help' | t }}</h2>
        <p class="faq-contact__description">{{ section.settings.contact_description | default: 'sections.page_faq.contact_us' | t }}</p>
        <div class="faq-contact__actions">
          {%- if section.settings.contact_phone != blank -%}
          <a href="tel:{{ section.settings.contact_phone | replace: ' ', '' }}" class="faq-contact__btn faq-contact__btn--phone">
            {%- render 'icon', name: 'phone', size: '18' -%}
            <span>{{ section.settings.contact_phone }}</span>
          </a>
          {%- endif -%}
          {%- if section.settings.contact_email != blank -%}
          <a href="mailto:{{ section.settings.contact_email }}" class="faq-contact__btn faq-contact__btn--email">
            {%- render 'icon', name: 'email', size: '18' -%}
            <span>{{ section.settings.contact_email }}</span>
          </a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>
  {%- endif -%}

  {%- if page.content != blank -%}
  <section class="faq-content section-padding">
    <div class="page-width">
      <div class="faq-content__wrap">
        {{ page.content }}
      </div>
    </div>
  </section>
  {%- endif -%}
</faq-page>

{% schema %}
{
  "name": "t:sections.page_faq.name",
  "tag": "section",
  "class": "section-page-faq",
  "settings": [
    { "type": "header", "content": "t:sections.page_faq.settings.header__hero.content" },
    { "type": "text", "id": "title", "label": "t:sections.page_faq.settings.title.label" },
    { "type": "textarea", "id": "description", "label": "t:sections.page_faq.settings.description.label" },
    { "type": "header", "content": "t:sections.page_faq.settings.header__contact.content" },
    { "type": "checkbox", "id": "show_contact", "label": "t:sections.page_faq.settings.show_contact.label", "default": true },
    { "type": "text", "id": "contact_title", "label": "t:sections.page_faq.settings.contact_title.label" },
    { "type": "textarea", "id": "contact_description", "label": "t:sections.page_faq.settings.contact_description.label" },
    { "type": "text", "id": "contact_phone", "label": "t:sections.page_faq.settings.contact_phone.label" },
    { "type": "text", "id": "contact_email", "label": "t:sections.page_faq.settings.contact_email.label" }
  ],
  "blocks": [
    {
      "type": "group",
      "name": "t:sections.page_faq.blocks.group.name",
      "limit": 5,
      "settings": [
        { "type": "text", "id": "title", "label": "t:sections.page_faq.blocks.group.settings.title.label" }
      ]
    },
    {
      "type": "question",
      "name": "t:sections.page_faq.blocks.question.name",
      "limit": 50,
      "settings": [
        { "type": "text", "id": "question", "label": "t:sections.page_faq.blocks.question.settings.question.label" },
        { "type": "richtext", "id": "answer", "label": "t:sections.page_faq.blocks.question.settings.answer.label" },
        { "type": "text", "id": "group", "label": "t:sections.page_faq.blocks.question.settings.group.label", "info": "t:sections.page_faq.blocks.question.settings.group.info" }
      ]
    }
  ]
}
{% endschema %}